<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="InventiFind.Settings"
    BackgroundColor="#F2F4F7"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- TOP NAVIGATION -->
        <!-- TOP NAVIGATION -->
        <Grid Grid.Row="0"
      BackgroundColor="#C8102E"
      Padding="25,18"
      ColumnDefinitions="Auto,Auto,*"
      RowDefinitions="Auto,Auto"
      RowSpacing="10">

            <!-- CLOSE BUTTON -->
            <Button Grid.Row="0"
            Grid.Column="0"
            Text="✕"
            WidthRequest="45"
            HeightRequest="40"
            BackgroundColor="White"
            TextColor="#C8102E"
            CornerRadius="10"
            FontSize="18"
            FontAttributes="Bold"
            Clicked="OnBackClicked"/>

            <!-- TITLE -->
            <Label Grid.Row="0"
           Grid.Column="1"
           Text="Settings"
           FontSize="28"
           FontAttributes="Bold"
           TextColor="White"
           VerticalOptions="Center"
           Margin="15,0,0,0"/>

            <!-- RESPONSIVE NAV ACTIONS -->
            <FlexLayout Grid.Row="1"
                Grid.ColumnSpan="3"
                Direction="Row"
                Wrap="Wrap"
                JustifyContent="End"
                AlignItems="Center">

                <!-- PROFILE -->
                <Grid Padding="15,8"
              Margin="0,0,8,8">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileTapped"/>
                    </Grid.GestureRecognizers>

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="👤"
                       FontSize="18"
                       TextColor="White"/>
                        <Label Text="Profile"
                       FontSize="16"
                       TextColor="White"/>
                    </HorizontalStackLayout>
                </Grid>

                <!-- REPORTS -->
                <Grid Padding="15,8"
              Margin="0,0,8,8">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReportsTapped"/>
                    </Grid.GestureRecognizers>

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📋"
                       FontSize="18"
                       TextColor="White"/>
                        <Label Text="Reports"
                       FontSize="16"
                       TextColor="White"/>
                    </HorizontalStackLayout>
                </Grid>

                <!-- LOGOUT -->
                <Button Text="Logout"
                WidthRequest="100"
                HeightRequest="40"
                BackgroundColor="White"
                TextColor="#C8102E"
                CornerRadius="10"
                Margin="0,0,0,8"
                Clicked="OnLogoutClicked"/>

            </FlexLayout>
        </Grid>

        <!-- MAIN CONTENT -->
        <ScrollView Grid.Row="1">
            <Grid Padding="35">

                <!-- PROFILE TAB -->
                <VerticalStackLayout x:Name="ProfileTabContent"
                                     Spacing="25"
                                     IsVisible="True">

                    <Label Text="Profile settings"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="#111827"/>

                    <Label Text="Manage your account information and credentials"
                           FontSize="14"
                           TextColor="#6B7280"/>

                    <!-- PROFILE CARD -->
                    <Frame BackgroundColor="White"
                           CornerRadius="18"
                           Padding="25"
                           BorderColor="#E5E7EB"
                           HasShadow="False">

                        <VerticalStackLayout Spacing="20">

                            <HorizontalStackLayout Spacing="15">
                                <Frame WidthRequest="70"
                                       HeightRequest="70"
                                       CornerRadius="35"
                                       BackgroundColor="#FEE2E2"
                                       Padding="0"
                                       HasShadow="False">

                                    <Label x:Name="InitialsLabel"
                                           Text="JD"
                                           FontSize="28"
                                           TextColor="#C8102E"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>

                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label x:Name="FullNameLabel"
                                           FontSize="22"
                                           FontAttributes="Bold"
                                           TextColor="#111827"/>

                                    <Label x:Name="RoleLabel"
                                           FontSize="13"
                                           TextColor="#4B5563"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <Label Text="PERSONAL INFO"
                                   TextColor="#C8102E"
                                   FontSize="14"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">

                                <Frame Grid.Column="0"
                                       Padding="10,4"
                                       BackgroundColor="#F3F4F6"
                                       BorderColor="#D1D5DB"
                                       CornerRadius="10"
                                       HasShadow="False">
                                    <Entry x:Name="FirstNameEntry"
                                           Placeholder="First name"
                                           BackgroundColor="Transparent"
                                           TextColor="#374151"
                                           PlaceholderColor="#9CA3AF"/>
                                </Frame>

                                <Frame Grid.Column="1"
                                       Padding="10,4"
                                       BackgroundColor="#F3F4F6"
                                       BorderColor="#D1D5DB"
                                       CornerRadius="10"
                                       HasShadow="False">
                                    <Entry x:Name="LastNameEntry"
                                           Placeholder="Last name"
                                           BackgroundColor="Transparent"
                                           TextColor="#374151"
                                           PlaceholderColor="#9CA3AF"/>
                                </Frame>

                            </Grid>

                            <Frame Padding="10,4"
                                   BackgroundColor="#F3F4F6"
                                   BorderColor="#D1D5DB"
                                   CornerRadius="10"
                                   HasShadow="False">
                                <Entry x:Name="EmailEntry"
                                       Placeholder="Email"
                                       BackgroundColor="Transparent"
                                       TextColor="#374151"
                                       PlaceholderColor="#9CA3AF"/>
                            </Frame>

                            <Button Text="Save Changes"
                                    BackgroundColor="#C8102E"
                                    TextColor="White"
                                    CornerRadius="12"
                                    HeightRequest="45"
                                    Clicked="OnSaveProfileClicked"/>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- PASSWORD CARD -->
                    <Frame BackgroundColor="White"
                           CornerRadius="18"
                           Padding="25"
                           BorderColor="#E5E7EB"
                           HasShadow="False">

                        <VerticalStackLayout Spacing="18">

                            <Label Text="CHANGE PASSWORD"
                                   TextColor="#C8102E"/>

                            <Frame Padding="10,4"
                                   BackgroundColor="#F3F4F6"
                                   BorderColor="#D1D5DB"
                                   CornerRadius="10"
                                   HasShadow="False">
                                <Entry x:Name="CurrentPasswordEntry"
                                       Placeholder="Current password"
                                       IsPassword="True"
                                       BackgroundColor="Transparent"
                                       TextColor="#374151"
                                       PlaceholderColor="#9CA3AF"/>
                            </Frame>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">

                                <Frame Grid.Column="0"
                                       Padding="10,4"
                                       BackgroundColor="#F3F4F6"
                                       BorderColor="#D1D5DB"
                                       CornerRadius="10"
                                       HasShadow="False">
                                    <Entry x:Name="NewPasswordEntry"
                                           Placeholder="New password"
                                           IsPassword="True"
                                           BackgroundColor="Transparent"
                                           TextColor="#374151"
                                           PlaceholderColor="#9CA3AF"/>
                                </Frame>

                                <Frame Grid.Column="1"
                                       Padding="10,4"
                                       BackgroundColor="#F3F4F6"
                                       BorderColor="#D1D5DB"
                                       CornerRadius="10"
                                       HasShadow="False">
                                    <Entry x:Name="ConfirmPasswordEntry"
                                           Placeholder="Confirm password"
                                           IsPassword="True"
                                           BackgroundColor="Transparent"
                                           TextColor="#374151"
                                           PlaceholderColor="#9CA3AF"/>
                                </Frame>

                            </Grid>

                            <Button Text="Update Password"
                                    BackgroundColor="#C8102E"
                                    TextColor="White"
                                    CornerRadius="12"
                                    HeightRequest="45"
                                    Clicked="OnUpdatePasswordClicked"/>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>

                <!-- REPORTS TAB -->
                <!-- REPORTS TAB -->
                <VerticalStackLayout x:Name="ReportsTabContent"
                     Spacing="20"
                     IsVisible="False">

                    <!-- HEADER -->
                    <Label Text="Reports"
           FontSize="32"
           FontAttributes="Bold"
           TextColor="#111827"/>

                    <Label Text="All reports submitted by this user"
           FontSize="14"
           TextColor="#6B7280"/>

                    <!-- TABLE HEADER -->
                    <Grid ColumnDefinitions="2*,1*,1*"
          Padding="15,10"
          BackgroundColor="#E5E7EB"
          Margin="0,10,0,0">

                        <Label Text="Item Name"
               FontAttributes="Bold"
               FontSize="14"
               TextColor="#111827"/>

                        <Label Grid.Column="1"
               Text="Type"
               FontAttributes="Bold"
               FontSize="14"
               TextColor="#111827"
               HorizontalTextAlignment="Center"/>

                        <Label Grid.Column="2"
               Text="Date"
               FontAttributes="Bold"
               FontSize="14"
               TextColor="#111827"
               HorizontalTextAlignment="End"/>
                    </Grid>

                    <!-- TABLE ROWS -->
                    <CollectionView x:Name="ReportsCollection"
                    SelectionMode="None">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="White"
                       BorderColor="#E5E7EB"
                       CornerRadius="12"
                       Padding="15,12"
                       Margin="0,0,0,10"
                       HasShadow="False">

                                    <Grid ColumnDefinitions="2*,1*,1*"
                          VerticalOptions="Center">

                                        <!-- ITEM NAME -->
                                        <Label Text="{Binding ItemName}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               VerticalOptions="Center"/>

                                        <!-- REPORT TYPE -->
                                        <Frame Grid.Column="1"
                               BackgroundColor="#FEE2E2"
                               Padding="8,4"
                               CornerRadius="8"
                               HasShadow="False"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">

                                            <Label Text="{Binding ReportType}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#C8102E"
                                   HorizontalTextAlignment="Center"/>
                                        </Frame>

                                        <!-- DATE -->
                                        <Label Grid.Column="2"
                               Text="{Binding DateReported}"
                               FontSize="13"
                               TextColor="#6B7280"
                               HorizontalTextAlignment="End"
                               VerticalOptions="Center"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Grid ColumnDefinitions="Auto,Auto,Auto"
          HorizontalOptions="End"
          Margin="0,15,0,0"
          ColumnSpacing="10">

                        <Button Text="◀"
                WidthRequest="40"
                HeightRequest="40"
                CornerRadius="8"
                BackgroundColor="#E5E7EB"
                TextColor="#111827"
                Clicked="OnPreviousPageClicked"/>

                        <Label x:Name="PaginationLabel"
               Grid.Column="1"
               Text="1"
               VerticalOptions="Center"
               FontSize="14"
               FontAttributes="Bold"
               TextColor="#111827"/>

                        <Button Text="▶"
                Grid.Column="2"
                WidthRequest="40"
                HeightRequest="40"
                CornerRadius="8"
                BackgroundColor="#E5E7EB"
                TextColor="#111827"
                Clicked="OnNextPageClicked"/>
                    </Grid>
                </VerticalStackLayout>

            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="InventiFind.ReturnModule"
    BackgroundColor="#F5E6E8"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="#B71C1C"
              HeightRequest="110">

            <Label Text="Return Assistance"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
        </Grid>

        <!-- BODY -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="15" Spacing="15">

                <!-- FILTER -->
                <Grid ColumnDefinitions="*,*,*"
                      ColumnSpacing="10">

                    <Button x:Name="OpenFilterBtn"
                            Text="Open"
                            BackgroundColor="#B71C1C"
                            TextColor="White"
                            CornerRadius="12"
                            Clicked="OnOpenFilterClicked"/>

                    <Button x:Name="ReturnedFilterBtn"
                            Grid.Column="1"
                            Text="Returned"
                            BackgroundColor="#E0E0E0"
                            TextColor="#555"
                            CornerRadius="12"
                            Clicked="OnReturnedFilterClicked"/>

                    <Button x:Name="MatchedFilterBtn"
                            Grid.Column="2"
                            Text="Matched"
                            BackgroundColor="#E0E0E0"
                            TextColor="#555"
                            CornerRadius="12"
                            Clicked="OnMatchedFilterClicked"/>
                </Grid>

                <!-- STATS -->
                <Frame BackgroundColor="White"
                       CornerRadius="15"
                       Padding="15"
                       HasShadow="True">

                    <VerticalStackLayout Spacing="5">
                        <Label x:Name="PendingCountLabel"
                               Text="0"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#C62828"/>

                        <Label x:Name="StatusTextLabel"
                               Text="Items ready for release"
                               FontSize="13"
                               TextColor="#666"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- DYNAMIC CARDS -->
                <VerticalStackLayout x:Name="ReturnCardsStack"
                                     Spacing="15"/>

                <!-- PAGINATION -->
                <HorizontalStackLayout x:Name="PaginationLayout"
                                       HorizontalOptions="End"
                                       Spacing="10"
                                       Margin="0,10,0,20"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- BOTTOM NAV -->
        <Frame Grid.Row="2"
       BackgroundColor="White"
       Padding="10,15"
       HasShadow="True">

            <Grid ColumnDefinitions="*,*,*,*,*">

                <!-- HOME -->
                <VerticalStackLayout Grid.Column="0"
                             HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHomeTapped"/>
                    </VerticalStackLayout.GestureRecognizers>

                    <Image Source="home.png"
                   WidthRequest="28"
                   HeightRequest="28"/>

                    <Label Text="Home"
                   FontSize="11"
                   TextColor="#888"/>
                </VerticalStackLayout>

                <!-- REPORTS -->
                <VerticalStackLayout Grid.Column="1"
                             HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReportsTapped"/>
                    </VerticalStackLayout.GestureRecognizers>

                    <Image Source="report.png"
                   WidthRequest="28"
                   HeightRequest="28"/>

                    <Label Text="Reports"
                   FontSize="11"
                   TextColor="#888"/>
                </VerticalStackLayout>

                <!-- REPORT ITEM -->
                <VerticalStackLayout Grid.Column="2"
                             HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReportItemTapped"/>
                    </VerticalStackLayout.GestureRecognizers>

                    <Image Source="addreport.png"
                   WidthRequest="28"
                   HeightRequest="28"/>

                    <Label Text="Add Report"
                   FontSize="11"
                   TextColor="#888"/>
                </VerticalStackLayout>

                <!-- RETURN ACTIVE -->
                <VerticalStackLayout Grid.Column="3"
                             Spacing="2"
                             HorizontalOptions="Center">

                    <Image Source="return.png"
                   WidthRequest="28"
                   HeightRequest="28"/>

                    <Label Text="Return"
                   FontSize="11"
                   TextColor="#C8102E"
                   FontAttributes="Bold"/>

                    <BoxView HeightRequest="2"
                     BackgroundColor="#C8102E"
                     CornerRadius="1"
                     Margin="0,-2,0,0"/>
                </VerticalStackLayout>

                <!-- SETTINGS -->
                <VerticalStackLayout Grid.Column="4"
                             HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSettingsTapped"/>
                    </VerticalStackLayout.GestureRecognizers>

                    <Image Source="gear.png"
                   WidthRequest="28"
                   HeightRequest="28"/>

                    <Label Text="Settings"
                   FontSize="11"
                   TextColor="#888"/>
                </VerticalStackLayout>

            </Grid>
        </Frame>
    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="InventiFind.FileReport"
    BackgroundColor="#66000000"
    Shell.NavBarIsVisible="False">

    <Grid>

        <!-- DARK OVERLAY -->
        <BoxView BackgroundColor="#66000000"/>

        <!-- RESPONSIVE MODAL -->
        <Frame Padding="20"
               CornerRadius="24"
               BackgroundColor="White"
               HasShadow="True"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               Margin="16"
               MaximumWidthRequest="560"
               MinimumWidthRequest="280">

            <ScrollView VerticalScrollBarVisibility="Never">

                <VerticalStackLayout Spacing="16">

                    <!-- TITLE -->
                    <Label Text="File Report"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#111827"/>

                    <Label Text="Report a lost or found item"
                           FontSize="14"
                           TextColor="#6B7280"/>

                    <!-- REPORT TYPE -->
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">

                        <Button x:Name="LostButton"
                                Grid.Column="0"
                                Text="Lost"
                                Clicked="OnLostTapped"
                                BackgroundColor="#C8102E"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="46"
                                FontAttributes="Bold"/>

                        <Button x:Name="FoundButton"
                                Grid.Column="1"
                                Text="Found"
                                Clicked="OnFoundTapped"
                                BackgroundColor="#F3F4F6"
                                TextColor="#374151"
                                CornerRadius="12"
                                HeightRequest="46"
                                FontAttributes="Bold"/>
                    </Grid>

                    <!-- ITEM NAME -->
                    <Frame BackgroundColor="#F9FAFB"
                           BorderColor="#E5E7EB"
                           CornerRadius="12"
                           Padding="12,6"
                           HasShadow="False">
                        <Entry x:Name="ItemNameEntry"
                               Placeholder="Item name"
                               PlaceholderColor="#9CA3AF"
                               BackgroundColor="Transparent"
                               TextColor="#374151"/>
                    </Frame>

                    <!-- CATEGORY -->
                    <Frame BackgroundColor="#F9FAFB"
                           BorderColor="#E5E7EB"
                           CornerRadius="12"
                           Padding="12,4"
                           HasShadow="False">
                        <Picker x:Name="CategoryPicker"
                                BackgroundColor="Transparent"
                                TextColor="#374151"
                                Title="Select category">
                            <Picker.Items>
                                <x:String>Phone</x:String>
                                <x:String>Wallet</x:String>
                                <x:String>ID</x:String>
                                <x:String>Watch</x:String>
                                <x:String>Keys</x:String>
                                <x:String>Others</x:String>
                            </Picker.Items>
                        </Picker>
                    </Frame>

                    <!-- DESCRIPTION -->
                    <Frame BackgroundColor="#F9FAFB"
                           BorderColor="#E5E7EB"
                           CornerRadius="12"
                           Padding="12,8"
                           HasShadow="False">
                        <Editor x:Name="DescriptionEditor"
                                Placeholder="Describe the item..."
                                HeightRequest="90"
                                AutoSize="TextChanges"
                                BackgroundColor="Transparent"
                                TextColor="#374151"/>
                    </Frame>

                    <!-- LOCATION -->
                    <Frame BackgroundColor="#F9FAFB"
                           BorderColor="#E5E7EB"
                           CornerRadius="12"
                           Padding="12,6"
                           HasShadow="False">
                        <Entry x:Name="LocationEntry"
                               Placeholder="Location where the item was found/lost"
                               PlaceholderColor="#9CA3AF"
                               BackgroundColor="Transparent"
                               TextColor="#374151"/>
                    </Frame>

                    <!-- DATE -->
                    <Frame BackgroundColor="#F9FAFB"
                           BorderColor="#E5E7EB"
                           CornerRadius="12"
                           Padding="12,4"
                           HasShadow="False">
                        <DatePicker x:Name="DatePicker"
                                    BackgroundColor="Transparent"
                                    TextColor="#374151"/>
                    </Frame>

                    <!-- IMAGE UPLOAD -->
                    <Frame BackgroundColor="#F9FAFB"
                           BorderColor="#D1D5DB"
                           CornerRadius="14"
                           Padding="16"
                           HasShadow="False">

                        <VerticalStackLayout Spacing="8">

                            <Label Text="📎 Upload image"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#374151"/>

                            <Label Text="PNG / JPG supported"
                                   FontSize="12"
                                   TextColor="#9CA3AF"/>

                            <Button Text="Choose File"
                                    Clicked="OnUploadTapped"
                                    BackgroundColor="#E5E7EB"
                                    TextColor="#374151"
                                    CornerRadius="10"
                                    HeightRequest="42"/>

                            <Label x:Name="UploadedFileNameLabel"
                                   Text="No file selected"
                                   FontSize="13"
                                   TextColor="#6B7280"
                                   FontAttributes="Italic"/>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- ACTION BUTTONS -->
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">

                        <Button Grid.Column="0"
                                Text="Cancel"
                                Clicked="OnCancelTapped"
                                BackgroundColor="#F3F4F6"
                                TextColor="#374151"
                                CornerRadius="12"
                                HeightRequest="46"/>

                        <Button Grid.Column="1"
                                Text="Submit"
                                Clicked="OnSubmitTapped"
                                BackgroundColor="#C8102E"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="46"
                                FontAttributes="Bold"/>
                    </Grid>

                </VerticalStackLayout>

            </ScrollView>
        </Frame>

    </Grid>
</ContentPage>
<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.ReportsModule"
             Title="Report Module"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FDF1F2">

    <Grid RowDefinitions="*,Auto">

        <!-- Main Scrollable Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Grid BackgroundColor="#B71C1C" HeightRequest="110">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Subtle decorative accent -->
                    <BoxView BackgroundColor="#9B1414" HeightRequest="3" VerticalOptions="End"/>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                        <Label Text="📋 Reports" FontSize="28" FontAttributes="Bold" TextColor="White"
                               HorizontalOptions="Center"/>
                        <Label x:Name="LblRecordCount" Text="Loading..." FontSize="12" TextColor="#FFCDD2"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Padding="14,16,14,0" Spacing="12">

                    <!-- Search Bar -->
                    <Frame BackgroundColor="White" CornerRadius="22" Padding="14,10" HasShadow="True">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="🔍" FontSize="17" TextColor="#999" VerticalOptions="Center"/>
                            <Entry x:Name="SearchEntry"
                                   Placeholder="Search reports, items..."
                                   FontSize="14" TextColor="#333"
                                   PlaceholderColor="#BBBBBB"
                                   VerticalOptions="Center"
                                   HorizontalOptions="FillAndExpand"
                                   ReturnType="Search"
                                   TextChanged="OnSearchTextChanged"/>
                            <!-- Clear button -->
                            <Label x:Name="LblClear" Text="✕" FontSize="15" TextColor="#AAAAAA"
                                   VerticalOptions="Center" IsVisible="False">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnClearSearch"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                    </Frame>

                    <!-- Filter Chips Row -->
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout Spacing="8" Padding="2,2">

                            <!-- All Items chip -->
                            <Frame x:Name="ChipAll" BackgroundColor="#B71C1C" CornerRadius="18"
                                   Padding="14,7" HasShadow="False">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFilterAll"/>
                                </Frame.GestureRecognizers>
                                <Label Text="All Items" FontSize="13" FontAttributes="Bold" TextColor="White"/>
                            </Frame>

                            <!-- Lost Items chip -->
                            <Frame x:Name="ChipLost" BackgroundColor="White" CornerRadius="18"
                                   Padding="14,7" HasShadow="False">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFilterLost"/>
                                </Frame.GestureRecognizers>
                                <Label Text="Lost Items" FontSize="13" TextColor="#888"/>
                            </Frame>

                            <!-- Found Items chip -->
                            <Frame x:Name="ChipFound" BackgroundColor="White" CornerRadius="18"
                                   Padding="14,7" HasShadow="False">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFilterFound"/>
                                </Frame.GestureRecognizers>
                                <Label Text="Found Items" FontSize="13" TextColor="#888"/>
                            </Frame>

                            <!-- Status separator / divider label -->
                            <BoxView BackgroundColor="#E0E0E0" WidthRequest="1" HeightRequest="28" VerticalOptions="Center"/>

                            <!-- Pending chip -->
                            <Frame x:Name="ChipPending" BackgroundColor="White" CornerRadius="18"
                                   Padding="14,7" HasShadow="False">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFilterPending"/>
                                </Frame.GestureRecognizers>
                                <Label Text="🕐 Pending" FontSize="13" TextColor="#888"/>
                            </Frame>

                            <!-- Matched chip -->
                            <Frame x:Name="ChipMatched" BackgroundColor="White" CornerRadius="18"
                                   Padding="14,7" HasShadow="False">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFilterMatched"/>
                                </Frame.GestureRecognizers>
                                <Label Text="✅ Matched" FontSize="13" TextColor="#888"/>
                            </Frame>

                            <!-- Open chip -->
                            <Frame x:Name="ChipOpen" BackgroundColor="White" CornerRadius="18"
                                   Padding="14,7" HasShadow="False">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFilterOpen"/>
                                </Frame.GestureRecognizers>
                                <Label Text="🔓 Open" FontSize="13" TextColor="#888"/>
                            </Frame>

                        </HorizontalStackLayout>
                    </ScrollView>

                    <!-- Loading indicator -->
                    <ActivityIndicator x:Name="LoadingIndicator" IsRunning="True" IsVisible="True"
                                       Color="#B71C1C" HorizontalOptions="Center"/>

                    <!-- Empty state -->
                    <VerticalStackLayout x:Name="EmptyState" IsVisible="False"
                                         HorizontalOptions="Center" Padding="20,40" Spacing="10">
                        <Label Text="📭" FontSize="48" HorizontalOptions="Center"/>
                        <Label Text="No reports found" FontSize="16" FontAttributes="Bold"
                               TextColor="#666" HorizontalOptions="Center"/>
                        <Label Text="Try adjusting your search or filters."
                               FontSize="13" TextColor="#999" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Report Cards Container -->
                    <VerticalStackLayout x:Name="ReportsContainer" Spacing="12"/>

                    <BoxView HeightRequest="16" BackgroundColor="Transparent"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Fixed Bottom Navigation -->
        <Frame Grid.Row="2"
       BackgroundColor="White"
       Padding="10,15"
       HasShadow="True">

            <Grid ColumnDefinitions="*,*,*,*,*">

                <!-- HOME -->
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHomeTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="home.png" WidthRequest="28" HeightRequest="28"/>
                    <Label Text="Home" FontSize="11" TextColor="#888"/>
                </VerticalStackLayout>

                <!-- REPORTS ACTIVE -->
                <VerticalStackLayout Grid.Column="1"
                             Spacing="2"
                             HorizontalOptions="Center">
                    <Image Source="report.png" WidthRequest="28" HeightRequest="28"/>
                    <Label Text="Reports"
                   FontSize="11"
                   TextColor="#C8102E"
                   FontAttributes="Bold"/>
                    <BoxView HeightRequest="2"
                     BackgroundColor="#C8102E"/>
                </VerticalStackLayout>

                <!-- REPORT ITEM -->
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReportItemTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="addreport.png" WidthRequest="28" HeightRequest="28"/>
                    <Label Text="Add Report" FontSize="11" TextColor="#888"/>
                </VerticalStackLayout>

                <!-- RETURN -->
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReturnTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="return.png" WidthRequest="28" HeightRequest="28"/>
                    <Label Text="Return" FontSize="11" TextColor="#888"/>
                </VerticalStackLayout>

                <!-- SETTINGS -->
                <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSettingsTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="gear.png" WidthRequest="28" HeightRequest="28"/>
                    <Label Text="Settings" FontSize="11" TextColor="#888"/>
                </VerticalStackLayout>

            </Grid>
        </Frame>
    </Grid>
</ContentPage>

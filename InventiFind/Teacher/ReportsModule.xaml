<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.ReportsModule"
             Title="Report Module"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FDF1F2">

    <Grid RowDefinitions="*,Auto">

        <!-- MAIN CONTENT -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- HEADER -->
                <Grid BackgroundColor="#B71C1C"
                      HeightRequest="110"
                      Padding="15,0">

                    <BoxView BackgroundColor="#9B1414"
                             HeightRequest="3"
                             VerticalOptions="End"/>

                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Spacing="2">

                        <Label Text="📋 Reports"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>

                        <Label x:Name="LblRecordCount"
                               Text="Loading..."
                               FontSize="12"
                               TextColor="#FFCDD2"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- BODY -->
                <VerticalStackLayout Padding="14,16"
                                     Spacing="12">

                    <!-- SEARCH -->
                    <Frame BackgroundColor="White"
                           CornerRadius="22"
                           Padding="14,10"
                           HasShadow="True"
                           HorizontalOptions="FillAndExpand">

                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="10">

                            <Label Grid.Column="0"
                                   Text="🔍"
                                   FontSize="17"
                                   TextColor="#999"
                                   VerticalOptions="Center"/>

                            <Entry Grid.Column="1"
                                   x:Name="SearchEntry"
                                   Placeholder="Search reports, items..."
                                   FontSize="14"
                                   TextColor="#333"
                                   PlaceholderColor="#BBBBBB"
                                   HorizontalOptions="FillAndExpand"
                                   ReturnType="Search"
                                   TextChanged="OnSearchTextChanged"/>

                            <Label Grid.Column="2"
                                   x:Name="LblClear"
                                   Text="✕"
                                   FontSize="15"
                                   TextColor="#AAAAAA"
                                   VerticalOptions="Center"
                                   IsVisible="False">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnClearSearch"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Frame>

                    <!-- RESPONSIVE FILTER CHIPS -->
                    <FlexLayout Direction="Row"
                                Wrap="Wrap"
                                JustifyContent="Start"
                                AlignItems="Start"
                                AlignContent="Start">

                        <Frame x:Name="ChipAll"
                               BackgroundColor="#B71C1C"
                               CornerRadius="18"
                               Padding="14,7"
                               Margin="4"
                               HasShadow="False">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFilterAll"/>
                            </Frame.GestureRecognizers>
                            <Label Text="All Items"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                        </Frame>

                        <Frame x:Name="ChipLost"
                               BackgroundColor="White"
                               CornerRadius="18"
                               Padding="14,7"
                               Margin="4"
                               HasShadow="False">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFilterLost"/>
                            </Frame.GestureRecognizers>
                            <Label Text="Lost Items"
                                   FontSize="13"
                                   TextColor="#888"/>
                        </Frame>

                        <Frame x:Name="ChipFound"
                               BackgroundColor="White"
                               CornerRadius="18"
                               Padding="14,7"
                               Margin="4"
                               HasShadow="False">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFilterFound"/>
                            </Frame.GestureRecognizers>
                            <Label Text="Found Items"
                                   FontSize="13"
                                   TextColor="#888"/>
                        </Frame>

                        <Frame x:Name="ChipPending"
                               BackgroundColor="White"
                               CornerRadius="18"
                               Padding="14,7"
                               Margin="4"
                               HasShadow="False">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFilterPending"/>
                            </Frame.GestureRecognizers>
                            <Label Text="🕐 Pending"
                                   FontSize="13"
                                   TextColor="#888"/>
                        </Frame>

                        <Frame x:Name="ChipMatched"
                               BackgroundColor="White"
                               CornerRadius="18"
                               Padding="14,7"
                               Margin="4"
                               HasShadow="False">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFilterMatched"/>
                            </Frame.GestureRecognizers>
                            <Label Text="✅ Matched"
                                   FontSize="13"
                                   TextColor="#888"/>
                        </Frame>

                        <Frame x:Name="ChipOpen"
                               BackgroundColor="White"
                               CornerRadius="18"
                               Padding="14,7"
                               Margin="4"
                               HasShadow="False">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFilterOpen"/>
                            </Frame.GestureRecognizers>
                            <Label Text="🔓 Open"
                                   FontSize="13"
                                   TextColor="#888"/>
                        </Frame>

                    </FlexLayout>

                    <!-- LOADING -->
                    <ActivityIndicator x:Name="LoadingIndicator"
                                       IsRunning="True"
                                       IsVisible="True"
                                       Color="#B71C1C"
                                       HorizontalOptions="Center"/>

                    <!-- EMPTY STATE -->
                    <VerticalStackLayout x:Name="EmptyState"
                                         IsVisible="False"
                                         HorizontalOptions="Center"
                                         Padding="20,40"
                                         Spacing="10">

                        <Label Text="📭"
                               FontSize="48"
                               HorizontalOptions="Center"/>

                        <Label Text="No reports found"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#666"
                               HorizontalOptions="Center"/>

                        <Label Text="Try adjusting your search or filters."
                               FontSize="13"
                               TextColor="#999"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- REPORTS -->
                    <VerticalStackLayout x:Name="ReportsContainer"
                                         Spacing="12"
                                         HorizontalOptions="FillAndExpand"/>

                    <BoxView HeightRequest="20"
                             BackgroundColor="Transparent"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- FIXED BOTTOM NAV -->
        <Frame Grid.Row="1"
               BackgroundColor="White"
               Padding="10,12"
               HasShadow="True"
               CornerRadius="0">

            <Grid ColumnDefinitions="*,*,*,*,*">

                <VerticalStackLayout Grid.Column="0"
                                     HorizontalOptions="Center"
                                     Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHomeTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="home.png" WidthRequest="24" HeightRequest="24"/>
                    <Label Text="Home" FontSize="11" TextColor="#888"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1"
                                     HorizontalOptions="Center"
                                     Spacing="2">
                    <Image Source="report.png" WidthRequest="24" HeightRequest="24"/>
                    <Label Text="Reports"
                           FontSize="11"
                           TextColor="#C8102E"
                           FontAttributes="Bold"/>
                    <BoxView HeightRequest="2"
                             WidthRequest="30"
                             BackgroundColor="#C8102E"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2"
                                     HorizontalOptions="Center"
                                     Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReportItemTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="addreport.png" WidthRequest="24" HeightRequest="24"/>
                    <Label Text="Add Report" FontSize="11" TextColor="#888"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3"
                                     HorizontalOptions="Center"
                                     Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReturnTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="return.png" WidthRequest="24" HeightRequest="24"/>
                    <Label Text="Return" FontSize="11" TextColor="#888"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="4"
                                     HorizontalOptions="Center"
                                     Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSettingsTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="gear.png" WidthRequest="24" HeightRequest="24"/>
                    <Label Text="Settings" FontSize="11" TextColor="#888"/>
                </VerticalStackLayout>

            </Grid>
        </Frame>

    </Grid>
</ContentPage>
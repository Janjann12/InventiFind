<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.TeacherDashboard"
             Title="Teacher Panel"
             Shell.NavBarIsVisible="False"
             
             BackgroundColor="#F5E6E8">

    <Grid RowDefinitions="*,Auto">

        <!-- Main Scrollable Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Grid BackgroundColor="#B71C1C" HeightRequest="120" VerticalOptions="Start">
                    <Label Text="Teacher Panel" FontSize="32" FontAttributes="Bold" TextColor="White"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>

                <BoxView HeightRequest="3" BackgroundColor="#9B59B6"/>

                <VerticalStackLayout Padding="15" Spacing="15">

                    <!-- Stats Cards -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Frame Grid.Column="0" BackgroundColor="White" CornerRadius="15" Padding="15">
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <BoxView HeightRequest="45" WidthRequest="45" CornerRadius="12" BackgroundColor="#87CEEB"/>
                                <Label Text="{Binding TotalReports}" FontSize="24" FontAttributes="Bold" TextColor="#333" HorizontalOptions="Center"/>
                                <Label Text="Total Reports" FontSize="12" FontAttributes="Bold" TextColor="#333" HorizontalOptions="Center"/> 
                                
                            </VerticalStackLayout>
                        </Frame>
                        <Frame Grid.Column="1" BackgroundColor="White" CornerRadius="15" Padding="15">
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <BoxView HeightRequest="45" WidthRequest="45" CornerRadius="12" BackgroundColor="#F08080"/>
                                <Label Text="{Binding LostItems}" FontSize="24" FontAttributes="Bold" TextColor="#333" HorizontalOptions="Center"/>
                                <Label Text="Lost Reports" FontSize="12" FontAttributes="Bold" TextColor="#333" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                        <Frame Grid.Column="2" BackgroundColor="White" CornerRadius="15" Padding="15">
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <BoxView HeightRequest="45" WidthRequest="45" CornerRadius="12" BackgroundColor="#98FB98"/>
                                <Label Text="{Binding FoundItems}" FontSize="24" FontAttributes="Bold" TextColor="#333" HorizontalOptions="Center"/>
                                <Label Text="Found Reports" FontSize="12" FontAttributes="Bold" TextColor="#333" HorizontalOptions="Center"/>

                            </VerticalStackLayout>
                        </Frame>
                    </Grid>

                    <!-- Categories - Fixed Layout (No Overlap) -->
                    <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Items by Category" FontSize="16" FontAttributes="Bold" TextColor="#333"/>

                            <!-- Phone -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Phone" FontSize="14" TextColor="#666" VerticalOptions="Center"/>

                                <!-- Progress Bar with Gray Track -->
                                <Grid Grid.Column="1" VerticalOptions="Center" HeightRequest="8">
                                    <!-- Gray background track -->
                                    <BoxView BackgroundColor="#E0E0E0" 
                         CornerRadius="4" 
                         HeightRequest="8" 
                         VerticalOptions="Center"/>
                                    <!-- Colored progress fill -->
                                    <ProgressBar Progress="{Binding PhoneProgress}" 
                             ProgressColor="#4169E1" 
                             HeightRequest="8" 
                             VerticalOptions="Center"/>
                                </Grid>

                                <Label Grid.Column="2" 
                   Text="{Binding PhoneCount}" 
                   FontSize="14" 
                   FontAttributes="Bold" 
                   TextColor="#333" 
                   VerticalOptions="Center" 
                   WidthRequest="35" 
                   HorizontalTextAlignment="End"/>
                            </Grid>

                            <!-- Wallet -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Wallet" FontSize="14" TextColor="#666" VerticalOptions="Center"/>

                                <Grid Grid.Column="1" VerticalOptions="Center" HeightRequest="8">
                                    <BoxView BackgroundColor="#E0E0E0" 
                         CornerRadius="4" 
                         HeightRequest="8" 
                         VerticalOptions="Center"/>
                                    <ProgressBar Progress="{Binding WalletProgress}" 
                             ProgressColor="#4169E1" 
                             HeightRequest="8" 
                             VerticalOptions="Center"/>
                                </Grid>

                                <Label Grid.Column="2" 
                   Text="{Binding WalletCount}" 
                   FontSize="14" 
                   FontAttributes="Bold" 
                   TextColor="#333" 
                   VerticalOptions="Center" 
                   WidthRequest="35" 
                   HorizontalTextAlignment="End"/>
                            </Grid>

                            <!-- ID -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="ID" FontSize="14" TextColor="#666" VerticalOptions="Center"/>

                                <Grid Grid.Column="1" VerticalOptions="Center" HeightRequest="8">
                                    <BoxView BackgroundColor="#E0E0E0" 
                         CornerRadius="4" 
                         HeightRequest="8" 
                         VerticalOptions="Center"/>
                                    <ProgressBar Progress="{Binding IdProgress}" 
                             ProgressColor="#4169E1" 
                             HeightRequest="8" 
                             VerticalOptions="Center"/>
                                </Grid>

                                <Label Grid.Column="2" 
                   Text="{Binding IdCount}" 
                   FontSize="14" 
                   FontAttributes="Bold" 
                   TextColor="#333" 
                   VerticalOptions="Center" 
                   WidthRequest="35" 
                   HorizontalTextAlignment="End"/>
                            </Grid>

                            <!-- Watch -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Watch" FontSize="14" TextColor="#666" VerticalOptions="Center"/>

                                <Grid Grid.Column="1" VerticalOptions="Center" HeightRequest="8">
                                    <BoxView BackgroundColor="#E0E0E0" 
                         CornerRadius="4" 
                         HeightRequest="8" 
                         VerticalOptions="Center"/>
                                    <ProgressBar Progress="{Binding WatchProgress}" 
                             ProgressColor="#4169E1" 
                             HeightRequest="8" 
                             VerticalOptions="Center"/>
                                </Grid>

                                <Label Grid.Column="2" 
                   Text="{Binding WatchCount}" 
                   FontSize="14" 
                   FontAttributes="Bold" 
                   TextColor="#333" 
                   VerticalOptions="Center" 
                   WidthRequest="35" 
                   HorizontalTextAlignment="End"/>
                            </Grid>

                            <!-- Others -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Others" FontSize="14" TextColor="#666" VerticalOptions="Center"/>

                                <Grid Grid.Column="1" VerticalOptions="Center" HeightRequest="8">
                                    <BoxView BackgroundColor="#E0E0E0" 
                         CornerRadius="4" 
                         HeightRequest="8" 
                         VerticalOptions="Center"/>
                                    <ProgressBar Progress="{Binding OthersProgress}" 
                             ProgressColor="#4169E1" 
                             HeightRequest="8" 
                             VerticalOptions="Center"/>
                                </Grid>

                                <Label Grid.Column="2" 
                   Text="{Binding OthersCount}" 
                   FontSize="14" 
                   FontAttributes="Bold" 
                   TextColor="#333" 
                   VerticalOptions="Center" 
                   WidthRequest="35" 
                   HorizontalTextAlignment="End"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Recent Reports -->
                    <CollectionView ItemsSource="{Binding Reports}" 
                Margin="0,5,0,0">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" 
                           ItemSpacing="12"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="#F0F0F0" 
                   CornerRadius="12" 
                   Padding="15" 
                   Margin="10,5">
                                    <Grid ColumnDefinitions="Auto,*,Auto" 
                      ColumnSpacing="15">

                                        <!-- Item Image -->
                                        <Frame Grid.Column="0" 
                           WidthRequest="70" 
                           HeightRequest="70" 
                           CornerRadius="12" 
                           Padding="0" 
                           IsClippedToBounds="True" 
                           VerticalOptions="Center"
                           BackgroundColor="#E0E0E0">
                                            <Image Source="{Binding ReportImage}" 
                               Aspect="AspectFill" 
                               WidthRequest="70" 
                               HeightRequest="70"/>
                                        </Frame>

                                        <!-- Content -->
                                        <VerticalStackLayout Grid.Column="1" 
                                         Spacing="6" 
                                         VerticalOptions="Center">

                                            <HorizontalStackLayout Spacing="10" 
                                               VerticalOptions="Center">
                                                <Label Text="{Binding Title}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#333"
                                   VerticalOptions="Center"/>

                                                <!-- Status Badge - Direct Color Binding -->
                                                <Frame CornerRadius="10"
                                   Padding="8,3"
                                   HasShadow="False"
                                   VerticalOptions="Center"
                                   BackgroundColor="{Binding StatusBgColor}">
                                                    <Label Text="{Binding Status}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="{Binding StatusTextColor}"/>
                                                </Frame>
                                            </HorizontalStackLayout>

                                            <Label Text="{Binding Description}" 
                               FontSize="12" 
                               TextColor="#888"
                               LineBreakMode="TailTruncation"
                               MaxLines="2"/>

                                            <Label Text="{Binding CreatedAt, StringFormat='⏱ {0:MMM d, h:mm tt}'}"
                               FontSize="11"
                               TextColor="#999"/>
                                        </VerticalStackLayout>

                                        <!-- Action Button -->
                                        <Frame Grid.Column="2"
                           BackgroundColor="#E6F3FF"
                           CornerRadius="15"
                           Padding="12,8"
                           VerticalOptions="Center"
                           HasShadow="False">
                                            <Label Text="View"
                               FontSize="12"
                               TextColor="#4169E1"
                               FontAttributes="Bold"/>
                                            <Frame.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewReportCommand}"
                                                  CommandParameter="{Binding .}"/>
                                            </Frame.GestureRecognizers>
                                        </Frame>

                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <BoxView HeightRequest="20" BackgroundColor="Transparent"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Fixed Bottom Navigation -->
        <Frame Grid.Row="1" BackgroundColor="White" CornerRadius="0" Padding="10,15" HasShadow="True">
            <Grid ColumnDefinitions="*,*,*,*">

                <!-- Dashboard -->
                <VerticalStackLayout Grid.Column="0" Spacing="5" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDashboardTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="⊞" FontSize="24" TextColor="#B71C1C" HorizontalOptions="Center"/>
                    <Label Text="Dashboard" FontSize="11" TextColor="#B71C1C" FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Reports -->
                <VerticalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReportsTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="📋" FontSize="22" TextColor="#888" HorizontalOptions="Center"/>
                    <Label Text="Reports" FontSize="11" TextColor="#888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Return/Back -->
                <VerticalStackLayout Grid.Column="2" Spacing="5" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReturnTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="↩" FontSize="24" TextColor="#888" HorizontalOptions="Center"/>
                    <Label Text="Return" FontSize="11" TextColor="#888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Log Out -->
                <VerticalStackLayout Grid.Column="3" Spacing="5" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="⎋" FontSize="24" TextColor="#888" HorizontalOptions="Center"/>
                    <Label Text="Log Out" FontSize="11" TextColor="#888" HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </Grid>
        </Frame>

    </Grid>
</ContentPage>
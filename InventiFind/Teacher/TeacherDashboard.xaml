<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.TeacherDashboard"
             Title="Teacher Panel"
             BackgroundColor="#F5E6E8">

    <Grid RowDefinitions="*,Auto">

        <!-- Main Scrollable Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Grid BackgroundColor="#B71C1C" HeightRequest="120" VerticalOptions="Start">
                    <Label Text="Teacher Panel" FontSize="32" FontAttributes="Bold" TextColor="White"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>

                <BoxView HeightRequest="3" BackgroundColor="#9B59B6"/>

                <VerticalStackLayout Padding="15" Spacing="15">

                    <!-- Stats Cards -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Frame Grid.Column="0" BackgroundColor="White" CornerRadius="15" Padding="15">
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <BoxView HeightRequest="45" WidthRequest="45" CornerRadius="12" BackgroundColor="#87CEEB"/>
                                <Label Text="Total Reports" FontSize="12" TextColor="#666" HorizontalOptions="Center"/>
                                <Label Text="1,234" FontSize="24" FontAttributes="Bold" TextColor="#333" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                        <Frame Grid.Column="1" BackgroundColor="White" CornerRadius="15" Padding="15">
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <BoxView HeightRequest="45" WidthRequest="45" CornerRadius="12" BackgroundColor="#F08080"/>
                                <Label Text="Lost Items" FontSize="12" TextColor="#666" HorizontalOptions="Center"/>
                                <Label Text="467" FontSize="24" FontAttributes="Bold" TextColor="#333" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                        <Frame Grid.Column="2" BackgroundColor="White" CornerRadius="15" Padding="15">
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <BoxView HeightRequest="45" WidthRequest="45" CornerRadius="12" BackgroundColor="#98FB98"/>
                                <Label Text="Found Items" FontSize="12" TextColor="#666" HorizontalOptions="Center"/>
                                <Label Text="741" FontSize="24" FontAttributes="Bold" TextColor="#333" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>

                    <!-- Categories - Fixed Layout (No Overlap) -->
                    <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Items by Category" FontSize="16" FontAttributes="Bold" TextColor="#333"/>

                            <!-- Phone -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Phone" FontSize="14" TextColor="#666" VerticalOptions="Center"/>
                                <ProgressBar Grid.Column="1" Progress="0.75" ProgressColor="#4169E1" HeightRequest="8" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="245" FontSize="14" FontAttributes="Bold" TextColor="#333" 
                                       VerticalOptions="Center" WidthRequest="35" HorizontalTextAlignment="End"/>
                            </Grid>

                            <!-- Wallet -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Wallet" FontSize="14" TextColor="#666" VerticalOptions="Center"/>
                                <ProgressBar Grid.Column="1" Progress="0.58" ProgressColor="#4169E1" HeightRequest="8" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="189" FontSize="14" FontAttributes="Bold" TextColor="#333" 
                                       VerticalOptions="Center" WidthRequest="35" HorizontalTextAlignment="End"/>
                            </Grid>

                            <!-- ID -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="ID" FontSize="14" TextColor="#666" VerticalOptions="Center"/>
                                <ProgressBar Grid.Column="1" Progress="0.48" ProgressColor="#4169E1" HeightRequest="8" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="156" FontSize="14" FontAttributes="Bold" TextColor="#333" 
                                       VerticalOptions="Center" WidthRequest="35" HorizontalTextAlignment="End"/>
                            </Grid>

                            <!-- Watch -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Watch" FontSize="14" TextColor="#666" VerticalOptions="Center"/>
                                <ProgressBar Grid.Column="1" Progress="0.30" ProgressColor="#4169E1" HeightRequest="8" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="98" FontSize="14" FontAttributes="Bold" TextColor="#333" 
                                       VerticalOptions="Center" WidthRequest="35" HorizontalTextAlignment="End"/>
                            </Grid>

                            <!-- Others -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Others" FontSize="14" TextColor="#666" VerticalOptions="Center"/>
                                <ProgressBar Grid.Column="1" Progress="1.0" ProgressColor="#4169E1" HeightRequest="8" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="547" FontSize="14" FontAttributes="Bold" TextColor="#333" 
                                       VerticalOptions="Center" WidthRequest="35" HorizontalTextAlignment="End"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Recent Reports -->
                    <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="Recent Reports" FontSize="16" FontAttributes="Bold" TextColor="#333"/>
                            <VerticalStackLayout Spacing="10">
                                <Frame BackgroundColor="#F0F0F0" CornerRadius="12" Padding="15">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                                            <HorizontalStackLayout Spacing="10">
                                                <Label Text="iPhone 14 Pro Max" FontSize="14" FontAttributes="Bold" TextColor="#333"/>
                                                <Frame BackgroundColor="#FFB6C1" CornerRadius="10" Padding="8,2" HasShadow="False">
                                                    <Label Text="Lost" FontSize="11" TextColor="#8B0000" FontAttributes="Bold"/>
                                                </Frame>
                                            </HorizontalStackLayout>
                                            <Label Text="blablabla" FontSize="12" TextColor="#888"/>
                                            <Label Text="⏱ 7 mins ago" FontSize="11" TextColor="#999"/>
                                        </VerticalStackLayout>
                                        <Frame Grid.Column="1" BackgroundColor="#E6F3FF" CornerRadius="15" Padding="12,6" VerticalOptions="Center">
                                            <Label Text="Status" FontSize="12" TextColor="#4169E1" FontAttributes="Bold"/>
                                        </Frame>
                                    </Grid>
                                </Frame>
                                <Frame BackgroundColor="#F0F0F0" CornerRadius="12" Padding="15">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                                            <HorizontalStackLayout Spacing="10">
                                                <Label Text="iPhone 14 Pro Max" FontSize="14" FontAttributes="Bold" TextColor="#333"/>
                                                <Frame BackgroundColor="#90EE90" CornerRadius="10" Padding="8,2" HasShadow="False">
                                                    <Label Text="Found" FontSize="11" TextColor="#006400" FontAttributes="Bold"/>
                                                </Frame>
                                            </HorizontalStackLayout>
                                            <Label Text="blablabla" FontSize="12" TextColor="#888"/>
                                            <Label Text="⏱ 7 mins ago" FontSize="11" TextColor="#999"/>
                                        </VerticalStackLayout>
                                        <Frame Grid.Column="1" BackgroundColor="#E6F3FF" CornerRadius="15" Padding="12,6" VerticalOptions="Center">
                                            <Label Text="Status" FontSize="12" TextColor="#4169E1" FontAttributes="Bold"/>
                                        </Frame>
                                    </Grid>
                                </Frame>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Frame>

                    <BoxView HeightRequest="20" BackgroundColor="Transparent"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Fixed Bottom Navigation -->
        <Frame Grid.Row="1" BackgroundColor="White" CornerRadius="0" Padding="10,15" HasShadow="True">
            <Grid ColumnDefinitions="*,*,*,*">
                <VerticalStackLayout Grid.Column="0" Spacing="5" HorizontalOptions="Center">
                    <Label Text="⊞" FontSize="24" TextColor="#B71C1C" HorizontalOptions="Center"/>
                    <Label Text="Dashboard" FontSize="11" TextColor="#B71C1C" FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="Center">
                    <Label Text="📋" FontSize="22" TextColor="#888" HorizontalOptions="Center"/>
                    <Label Text="Reports" FontSize="11" TextColor="#888" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" Spacing="5" HorizontalOptions="Center">
                    <Label Text="↩" FontSize="24" TextColor="#888" HorizontalOptions="Center"/>
                    <Label Text="Return" FontSize="11" TextColor="#888" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="3" Spacing="5" HorizontalOptions="Center">
                    <Label Text="⎋" FontSize="24" TextColor="#888" HorizontalOptions="Center"/>
                    <Label Text="Log Out" FontSize="11" TextColor="#888" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>
        </Frame>

    </Grid>
</ContentPage>
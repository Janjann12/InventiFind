<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.NotificationModule"
             BackgroundColor="#F2F4F7"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0"
              BackgroundColor="#C8102E"
              HeightRequest="100"
              VerticalOptions="Start">
            <Label Text="Announcements"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   Margin="0,20,0,0"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" Padding="16,16,16,20">

                <!-- Latest Update Card -->
                <Frame BackgroundColor="#C8102E"
                       BorderColor="Transparent"
                       CornerRadius="16"
                       Padding="15"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="6">
                        <HorizontalStackLayout Spacing="8">
                            <Ellipse Fill="White" Opacity="0.3"
                                     WidthRequest="16" HeightRequest="16"/>
                            <Label Text="Latest update"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                        </HorizontalStackLayout>
                        <Label Text="Our Lost &amp; Found office will be open extended hours this Saturday and Sunday from 8 AM to 8 PM to help more people reunite with their items."
                               TextColor="White"
                               Opacity="0.9"
                               FontSize="12"
                               LineHeight="1.4"/>
                        <Label Text="2026-04-12"
                               TextColor="#FFCDD2"
                               FontSize="11"
                               Margin="0,4,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- All Announcements Title -->
                <Label Text="All announcements"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="#111827"
                       Margin="0,6,0,0"/>

                <!-- Report Collection -->
                <CollectionView x:Name="ReportCollection"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BackgroundColor="White"
                                   CornerRadius="20"
                                   Padding="14"
                                   HasShadow="False"
                                   BorderColor="#E5E7EB"
                                   Margin="0,0,0,2">

                                <VerticalStackLayout Spacing="8">

                                    <!-- Title + Type Badge -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Title}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="#111827"
                                               VerticalOptions="Center"/>
                                        <Frame Grid.Column="1"
                                               Padding="9,3"
                                               CornerRadius="8"
                                               HasShadow="False"
                                               BorderColor="Transparent"
                                               BackgroundColor="{Binding RType, Converter={StaticResource TypeToColorConverter}}">
                                            <Label Text="{Binding RType}"
                                                   FontSize="10"
                                                   FontAttributes="Bold"
                                                   TextColor="White"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center"/>
                                        </Frame>
                                    </Grid>

                                    <!-- Description -->
                                    <Label Text="{Binding Description}"
                                           FontSize="12"
                                           TextColor="#4B5563"
                                           LineHeight="1.4"/>

                                    <!-- Date + Reported By -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Date}"
                                               FontSize="11"
                                               TextColor="#9CA3AF"
                                               VerticalOptions="Center"/>
                                        <HorizontalStackLayout Grid.Column="1" Spacing="4">
                                            <Label Text="By:"
                                                   FontSize="11"
                                                   TextColor="#9CA3AF"
                                                   VerticalOptions="Center"/>
                                            <Label Text="{Binding Author}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#111827"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Grid>

                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Pagination -->
                <HorizontalStackLayout x:Name="PageButtonsLayout"
                                       HorizontalOptions="End"
                                       Spacing="6"
                                       Margin="0,4,4,10"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <Grid Grid.Row="2"
              BackgroundColor="White"
              HeightRequest="70"
              ColumnDefinitions="*,*,*,*,*"
              Padding="0,10">

            <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                <Image Source="home.png" WidthRequest="28" HeightRequest="28" HorizontalOptions="Center"/>
                <Label Text="Home" FontSize="11" TextColor="#9CA3AF" HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                <Image Source="report.png" WidthRequest="28" HeightRequest="28" HorizontalOptions="Center"/>
                <Label Text="Report" FontSize="11" TextColor="#9CA3AF" HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                <Image Source="box.png" WidthRequest="28" HeightRequest="28" HorizontalOptions="Center"/>
                <Label Text="Receive" FontSize="11" TextColor="#9CA3AF" HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReceiveTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- News (Active) -->
            <VerticalStackLayout Grid.Column="3" Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                <Image Source="notif.png" WidthRequest="28" HeightRequest="28" HorizontalOptions="Center"/>
                <Label Text="News" FontSize="11" TextColor="#C8102E" FontAttributes="Bold" HorizontalOptions="Center"/>
                <BoxView HeightRequest="2" BackgroundColor="#C8102E" CornerRadius="1" Margin="0,-2,0,0"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNewsTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="4" Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                <Image Source="gear.png" WidthRequest="28" HeightRequest="28" HorizontalOptions="Center"/>
                <Label Text="Settings" FontSize="11" TextColor="#9CA3AF" HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>
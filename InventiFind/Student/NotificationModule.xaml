<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.NotificationModule"
             BackgroundColor="#F5E6E0"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0" 
              BackgroundColor="#B71C1C" 
              HeightRequest="120"
              VerticalOptions="Start">
            <Label Text="Announcements" 
                   FontSize="32" 
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   Margin="0,20,0,0"/>

            <!-- Curved Bottom -->
            <BoxView Grid.Row="0"
                     BackgroundColor="#F5E6E0"
                     HeightRequest="30"
                     VerticalOptions="End"
                     CornerRadius="30,30,0,0"
                     Margin="0,0,0,-15"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1" Margin="0,-10,0,0">
            <VerticalStackLayout Spacing="15" Padding="20,0">

                <!-- Latest Update Card -->
                <Frame BackgroundColor="#D32F2F"
                       BorderColor="Transparent"
                       CornerRadius="12"
                       Padding="15"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="📢" FontSize="18"/>
                            <Label Text="Latest Update" 
                                   FontSize="16" 
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                        </HorizontalStackLayout>
                        <Label Text="Our Lost &amp; Found office will be open extended hours this Saturday and Sunday from 8 AM to 8 PM to help more people reunite with their items"
                               TextColor="White"
                               FontSize="13"
                               LineHeight="1.3"/>
                        <Label Text="2026-04-12"
                               TextColor="#FFCDD2"
                               FontSize="11"
                               Margin="0,5,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- All Announcements Title -->
                <Label Text="All Announcements" 
                       FontSize="16" 
                       FontAttributes="Bold"
                       TextColor="#333"
                       Margin="0,10,0,0"/>

                <!-- Announcement Item 1 -->
                <Frame BackgroundColor="#D6E4F0"
                       BorderColor="#4A90E2"
                       CornerRadius="12"
                       Padding="15"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="6">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="ℹ️" FontSize="16"/>
                            <Label Text="Extended Hours This Weekend" 
                                   FontSize="15" 
                                   FontAttributes="Bold"
                                   TextColor="#333"/>
                        </HorizontalStackLayout>
                        <Label Text="Our Lost &amp; Found office will be open extended hours this Saturday and Sunday from 8 AM to 8 PM to help more people reunite with their items"
                               TextColor="#555"
                               FontSize="13"
                               LineHeight="1.3"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="2026-04-12"
                                   TextColor="#888"
                                   FontSize="11"
                                   VerticalOptions="Center"/>
                            <Label Text="by Admin Team"
                                   Grid.Column="1"
                                   TextColor="#888"
                                   FontSize="11"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Announcement Item 2 -->
                <Frame BackgroundColor="#FFF8E1"
                       BorderColor="#F9A825"
                       CornerRadius="12"
                       Padding="15"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="6">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="⚠️" FontSize="16"/>
                            <Label Text="Spring Cleaning Event" 
                                   FontSize="15" 
                                   FontAttributes="Bold"
                                   TextColor="#333"/>
                        </HorizontalStackLayout>
                        <Label Text="Unclaimed items older than 90 days will be donated to charity on April 30th. Please check if you have any pending claims."
                               TextColor="#555"
                               FontSize="13"
                               LineHeight="1.3"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="2026-04-12"
                                   TextColor="#888"
                                   FontSize="11"
                                   VerticalOptions="Center"/>
                            <Label Text="by Admin Team"
                                   Grid.Column="1"
                                   TextColor="#888"
                                   FontSize="11"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Empty Placeholder Card -->
                <Frame BackgroundColor="#D6E4F0"
                       BorderColor="#4A90E2"
                       CornerRadius="12"
                       HeightRequest="80"
                       HasShadow="False"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <Grid Grid.Row="2" 
              BackgroundColor="White"
              HeightRequest="70"
              ColumnDefinitions="*,*,*,*,*"
              Padding="0,10">

            <!-- Home -->
            <VerticalStackLayout Grid.Column="0" 
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="home.png"
                       WidthRequest="28"
                       HeightRequest="33"
                       HorizontalOptions="Center"/>
                <Label Text="Home" 
                       FontSize="11" 
                       TextColor="#666" 
                       HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Report -->
            <VerticalStackLayout Grid.Column="1" 
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="report.png"
                       WidthRequest="28"
                       HeightRequest="33"
                       HorizontalOptions="Center"/>
                <Label Text="Report" 
                       FontSize="11" 
                       TextColor="#666" 
                       HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Receive -->
            <VerticalStackLayout Grid.Column="2" 
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="box.png"
                       WidthRequest="28"
                       HeightRequest="33"
                       HorizontalOptions="Center"/>
                <Label Text="Receive" 
                       FontSize="11" 
                       TextColor="#666" 
                       HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReceiveTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- News (Active) -->
            <VerticalStackLayout Grid.Column="3" 
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="notif.png"
                       WidthRequest="28"
                       HeightRequest="33"
                       HorizontalOptions="Center"/>
                <Label Text="News" 
                       FontSize="11" 
                       TextColor="#B71C1C" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNewsTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Logout -->
            <VerticalStackLayout Grid.Column="4" 
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="logout.png"
                       WidthRequest="28"
                       HeightRequest="33"
                       HorizontalOptions="Center"/>
                <Label Text="Logout" 
                       FontSize="11" 
                       TextColor="#666" 
                       HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>
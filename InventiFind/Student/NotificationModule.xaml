<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.NotificationModule"
             BackgroundColor="#F5E6E0"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0" 
              BackgroundColor="#B71C1C" 
              HeightRequest="120"
              VerticalOptions="Start">
            <Label Text="Announcements" 
                   FontSize="32" 
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   Margin="0,20,0,0"/>

            <!-- Curved Bottom -->
            <BoxView BackgroundColor="#F5E6E0"
                     HeightRequest="30"
                     VerticalOptions="End"
                     CornerRadius="30,30,0,0"
                     Margin="0,0,0,-15"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1" Margin="0,-10,0,0">
            <VerticalStackLayout Spacing="15" Padding="20,0,20,20">

                <!-- Latest Update Card -->
                <Frame BackgroundColor="#D32F2F"
                       BorderColor="Transparent"
                       CornerRadius="12"
                       Padding="15"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="📢" FontSize="18"/>
                            <Label Text="Latest Update" 
                                   FontSize="16" 
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                        </HorizontalStackLayout>
                        <Label Text="Our Lost &amp; Found office will be open extended hours this Saturday and Sunday from 8 AM to 8 PM to help more people reunite with their items"
                               TextColor="White"
                               FontSize="13"
                               LineHeight="1.3"/>
                        <Label Text="2026-04-12"
                               TextColor="#FFCDD2"
                               FontSize="11"
                               Margin="0,5,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- All Announcements Title -->
                <Label Text="All Announcements" 
                       FontSize="16" 
                       FontAttributes="Bold"
                       TextColor="#333"
                       Margin="0,10,0,0"/>

                <!-- Report Collection -->
                <CollectionView x:Name="ReportCollection"
                                SelectionMode="None"
                                Margin="5">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="5"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BackgroundColor="#BFD9EC"
                                   CornerRadius="18"
                                   Padding="15"
                                   HasShadow="False"
                                   Margin="0,4">

                                <VerticalStackLayout Spacing="10">

                                    <!-- TOP ROW: TITLE + TYPE -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Title}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="Black"/>

                                        <Frame Grid.Column="1"
                                               Padding="8,3"
                                               CornerRadius="8"
                                               HasShadow="False"
                                               BorderColor="{Binding RType, Converter={StaticResource TypeToColorConverter}}"
                                               BackgroundColor="{Binding RType, Converter={StaticResource TypeToColorConverter}}">
                                            <Label Text="{Binding RType}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="White"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center"/>
                                        </Frame>
                                    </Grid>

                                    <!-- DESCRIPTION -->
                                    <Label Text="{Binding Description}"
                                           FontSize="13"
                                           TextColor="Black"/>

                                    <!-- DATE + VIEW BUTTON -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Date}"
                                               FontSize="11"
                                               TextColor="Black"
                                               Opacity="0.7"/>

                                        <Frame Grid.Column="1"
                                               BackgroundColor="#7FB069"
                                               Padding="10,4"
                                               CornerRadius="10"
                                               HasShadow="False">
                                            <Label Text="View"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="Black"/>
                                        </Frame>
                                    </Grid>

                                    <!-- REPORTED BY -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="Reported By:"
                                               FontSize="11"
                                               TextColor="Black"
                                               Opacity="0.7"/>

                                        <Label Grid.Column="1"
                                               Text="{Binding Author}"
                                               FontSize="13"
                                               TextColor="Black"
                                               FontAttributes="Bold"/>
                                    </Grid>

                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Pagination — bottom-right, inside the scroll area -->
                <HorizontalStackLayout x:Name="PageButtonsLayout"
                                       HorizontalOptions="End"
                                       Spacing="5"
                                       Margin="0,2,4,10"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <Grid Grid.Row="2" 
              BackgroundColor="White"
              HeightRequest="70"
              ColumnDefinitions="*,*,*,*,*"
              Padding="0,10">

            <!-- Home -->
            <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                <Image Source="home.png" WidthRequest="28" HeightRequest="33" HorizontalOptions="Center"/>
                <Label Text="Home" FontSize="11" TextColor="#666" HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Report -->
            <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                <Image Source="report.png" WidthRequest="28" HeightRequest="33" HorizontalOptions="Center"/>
                <Label Text="Report" FontSize="11" TextColor="#666" HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Receive -->
            <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                <Image Source="box.png" WidthRequest="28" HeightRequest="33" HorizontalOptions="Center"/>
                <Label Text="Receive" FontSize="11" TextColor="#666" HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReceiveTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- News (Active) -->
            <VerticalStackLayout Grid.Column="3" Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                <Image Source="notif.png" WidthRequest="28" HeightRequest="33" HorizontalOptions="Center"/>
                <Label Text="News" FontSize="11" TextColor="#B71C1C" FontAttributes="Bold" HorizontalOptions="Center"/>
                <BoxView HeightRequest="2" BackgroundColor="#B71C1C" CornerRadius="1" Margin="0,-2,0,0"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNewsTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Logout -->
            <VerticalStackLayout Grid.Column="4" Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                <Image Source="logout.png" WidthRequest="28" HeightRequest="33" HorizontalOptions="Center"/>
                <Label Text="Logout" FontSize="11" TextColor="#666" HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>

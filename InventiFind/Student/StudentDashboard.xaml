<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.StudentDashboard"
             Title="Student Dashboard"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Fixed Header Content (Not Scrollable) -->
        <VerticalStackLayout Grid.Row="0" Spacing="0">

            <!-- Header with Red Background -->
            <Grid BackgroundColor="#DC143C" 
                  Padding="20,40,20,30"
                  HeightRequest="180">

                <!-- App Name -->
                <Label Text="InventiFind"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Start"/>

                <!-- Search Bar -->
                <Frame BackgroundColor="White"
                       CornerRadius="25"
                       Padding="15,0"
                       HasShadow="True"
                       Margin="0,20,0,0"
                       VerticalOptions="End"
                       HeightRequest="50">
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Label Text="🔍" 
                               FontSize="16" 
                               TextColor="#999"
                               VerticalOptions="Center"/>
                        <Entry Placeholder="Search lost or Found Item"
                               PlaceholderColor="#999"
                               TextColor="#333"
                               FontSize="14"
                               VerticalOptions="Center"
                               HorizontalOptions="FillAndExpand"/>
                    </HorizontalStackLayout>
                </Frame>
            </Grid>

            <!-- Categories Section -->
            <VerticalStackLayout Padding="20,25,20,15" Spacing="15">

                <Label Text="Categories"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#1a1a1a"/>

                <!-- Category Icons Grid - Fixed: 5 columns -->
                <Grid ColumnDefinitions="*,*,*,*,*" 
                      RowDefinitions="Auto"
                      ColumnSpacing="10">

                    <!-- Phone -->
                    <VerticalStackLayout Grid.Column="0" Spacing="8">
                        <Frame BackgroundColor="White"
                               CornerRadius="15"
                               Padding="15"
                               HasShadow="False"
                               BorderColor="#E0E0E0"
                               HeightRequest="70"
                               WidthRequest="70"
                               HorizontalOptions="Center">
                            <Image Source="mobile.png"
                                   Aspect="AspectFit"
                                   HeightRequest="35"
                                   WidthRequest="35"/>
                        </Frame>
                        <Label Text="Phone"
                               FontSize="12"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Wallet -->
                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                        <Frame BackgroundColor="White"
                               CornerRadius="15"
                               Padding="15"
                               HasShadow="False"
                               BorderColor="#E0E0E0"
                               HeightRequest="70"
                               WidthRequest="70"
                               HorizontalOptions="Center">
                            <Image Source="wallet.png"
                                   Aspect="AspectFit"
                                   HeightRequest="35"
                                   WidthRequest="35"/>
                        </Frame>
                        <Label Text="Wallet"
                               FontSize="12"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Keys -->
                    <VerticalStackLayout Grid.Column="2" Spacing="8">
                        <Frame BackgroundColor="White"
                               CornerRadius="15"
                               Padding="15"
                               HasShadow="False"
                               BorderColor="#E0E0E0"
                               HeightRequest="70"
                               WidthRequest="70"
                               HorizontalOptions="Center">
                            <Image Source="id.png"
                                   Aspect="AspectFit"
                                   HeightRequest="35"
                                   WidthRequest="35"/>
                        </Frame>
                        <Label Text="ID"
                               FontSize="12"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Watch -->
                    <VerticalStackLayout Grid.Column="3" Spacing="8">
                        <Frame BackgroundColor="White"
                               CornerRadius="15"
                               Padding="15"
                               HasShadow="False"
                               BorderColor="#E0E0E0"
                               HeightRequest="70"
                               WidthRequest="70"
                               HorizontalOptions="Center">
                            <Image Source="watch1.png"
                                   Aspect="AspectFit"
                                   HeightRequest="35"
                                   WidthRequest="35"/>
                        </Frame>
                        <Label Text="Watch"
                               FontSize="12"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Others -->
                    <VerticalStackLayout Grid.Column="4" Spacing="8">
                        <Frame BackgroundColor="White"
                               CornerRadius="15"
                               Padding="15"
                               HasShadow="False"
                               BorderColor="#E0E0E0"
                               HeightRequest="70"
                               WidthRequest="70"
                               HorizontalOptions="Center">
                            <Image Source="dots.png"
                                   Aspect="AspectFit"
                                   HeightRequest="35"
                                   WidthRequest="35"/>
                        </Frame>
                        <Label Text="Others"
                               FontSize="12"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                </Grid>
            </VerticalStackLayout>

            <!-- Recent Post Header (Fixed) -->
            <Grid ColumnDefinitions="*,Auto" Padding="20,10,20,10">
                <Label Text="Recent Post"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#1a1a1a"
                       VerticalOptions="Center"/>
                <Label Text="View All"
                       FontSize="14"
                       TextColor="#DC143C"
                       FontAttributes="Bold"
                       Grid.Column="1"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnViewAllTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
        </VerticalStackLayout>

        <!-- Scrollable Recent Post Section Only -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,10,20,20" Spacing="15">

                <Frame BackgroundColor="White"
       CornerRadius="16"
       Padding="16"
       HasShadow="False">

                    <VerticalStackLayout Spacing="200">
          
                        

                    </VerticalStackLayout>
                </Frame>


                <!-- Bottom Spacing -->
                <BoxView HeightRequest="20" BackgroundColor="Transparent"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation Bar -->
        <Grid Grid.Row="2" 
              BackgroundColor="White"
              HeightRequest="70"
              ColumnDefinitions="*,*,*,*,*"
              Padding="0,10">

            <!-- Home -->
            <VerticalStackLayout Grid.Column="0" 
                         Spacing="2"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <Image Source="home.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Home" FontSize="11" TextColor="#B71C1C"/>
                <BoxView HeightRequest="2" BackgroundColor="#B71C1C" CornerRadius="1" Margin="0,-2,0,0"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Report -->
            <VerticalStackLayout Grid.Column="1" 
                         Spacing="2"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <Image Source="report.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Report" FontSize="11" TextColor="#666"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Receive (Active) -->
            <VerticalStackLayout Grid.Column="2" 
                         Spacing="2"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <Image Source="box.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Receive" FontSize="11" TextColor="#666" FontAttributes="Bold"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReceiveTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- News -->
            <VerticalStackLayout Grid.Column="3" 
                         Spacing="2"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <Image Source="notif.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="News" FontSize="11" TextColor="#666"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNewsTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Logout -->
            <VerticalStackLayout Grid.Column="4" 
                         Spacing="2"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <Image Source="logout.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Logout" FontSize="11" TextColor="#666"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>
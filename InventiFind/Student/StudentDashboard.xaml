<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.StudentDashboard"
             Title="Student Dashboard"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Fixed Header Content (Not Scrollable) -->
        <VerticalStackLayout Grid.Row="0" Spacing="0">

            <!-- Header with Red Background -->
            <Grid BackgroundColor="#DC143C" 
                  Padding="20,40,20,30"
                  HeightRequest="180">

                <!-- App Name -->
                <Label Text="InventiFind"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Start"/>

                <!-- Search Bar -->
                <Frame BackgroundColor="White"
                       CornerRadius="25"
                       Padding="15,0"
                       HasShadow="True"
                       Margin="0,20,0,0"
                       VerticalOptions="End"
                       HeightRequest="50">
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Label Text="🔍" 
                               FontSize="16" 
                               TextColor="#999"
                               VerticalOptions="Center"/>
                        <Entry Placeholder="Search lost or Found Item"
                               PlaceholderColor="#999"
                               TextColor="#333"
                               FontSize="14"
                               VerticalOptions="Center"
                               HorizontalOptions="FillAndExpand"/>
                    </HorizontalStackLayout>
                </Frame>
            </Grid>

            <!-- Categories Section -->
            <VerticalStackLayout Padding="20,25,20,15" Spacing="15">

                <Label Text="Categories"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#1a1a1a"/>

                <!-- Category Icons Grid - Fixed: 5 columns -->
                <Grid ColumnDefinitions="*,*,*,*,*" 
                      RowDefinitions="Auto"
                      ColumnSpacing="10">

                    <!-- Phone -->
                    <VerticalStackLayout Grid.Column="0" Spacing="8">
                        <Frame BackgroundColor="White"
                               CornerRadius="15"
                               Padding="15"
                               HasShadow="False"
                               BorderColor="#E0E0E0"
                               HeightRequest="70"
                               WidthRequest="70"
                               HorizontalOptions="Center">
                            <Image Source="Images/mobile.png"
                                   Aspect="AspectFit"
                                   HeightRequest="35"
                                   WidthRequest="35"/>
                        </Frame>
                        <Label Text="Phone"
                               FontSize="12"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Wallet -->
                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                        <Frame BackgroundColor="White"
                               CornerRadius="15"
                               Padding="15"
                               HasShadow="False"
                               BorderColor="#E0E0E0"
                               HeightRequest="70"
                               WidthRequest="70"
                               HorizontalOptions="Center">
                            <Image Source="Images/wallet.png"
                                   Aspect="AspectFit"
                                   HeightRequest="35"
                                   WidthRequest="35"/>
                        </Frame>
                        <Label Text="Wallet"
                               FontSize="12"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Keys -->
                    <VerticalStackLayout Grid.Column="2" Spacing="8">
                        <Frame BackgroundColor="White"
                               CornerRadius="15"
                               Padding="15"
                               HasShadow="False"
                               BorderColor="#E0E0E0"
                               HeightRequest="70"
                               WidthRequest="70"
                               HorizontalOptions="Center">
                            <Image Source="Images/id.png"
                                   Aspect="AspectFit"
                                   HeightRequest="35"
                                   WidthRequest="35"/>
                        </Frame>
                        <Label Text="ID"
                               FontSize="12"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Watch -->
                    <VerticalStackLayout Grid.Column="3" Spacing="8">
                        <Frame BackgroundColor="White"
                               CornerRadius="15"
                               Padding="15"
                               HasShadow="False"
                               BorderColor="#E0E0E0"
                               HeightRequest="70"
                               WidthRequest="70"
                               HorizontalOptions="Center">
                            <Image Source="Images/watch1.png"
                                   Aspect="AspectFit"
                                   HeightRequest="35"
                                   WidthRequest="35"/>
                        </Frame>
                        <Label Text="Watch"
                               FontSize="12"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Others -->
                    <VerticalStackLayout Grid.Column="4" Spacing="8">
                        <Frame BackgroundColor="White"
                               CornerRadius="15"
                               Padding="15"
                               HasShadow="False"
                               BorderColor="#E0E0E0"
                               HeightRequest="70"
                               WidthRequest="70"
                               HorizontalOptions="Center">
                            <Image Source="Images/dots.png"
                                   Aspect="AspectFit"
                                   HeightRequest="35"
                                   WidthRequest="35"/>
                        </Frame>
                        <Label Text="Others"
                               FontSize="12"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                </Grid>
            </VerticalStackLayout>

            <!-- Recent Post Header (Fixed) -->
            <Grid ColumnDefinitions="*,Auto" Padding="20,20,20,10">
                <Label Text="Recent Post"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#1a1a1a"
                       VerticalOptions="Center"/>
                <Label Text="View All"
                       FontSize="14"
                       TextColor="#DC143C"
                       FontAttributes="Bold"
                       Grid.Column="1"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnViewAllTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
        </VerticalStackLayout>

        <!-- Scrollable Recent Post Section Only -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,10,20,20" Spacing="15">

                <Frame BackgroundColor="White"
       CornerRadius="16"
       Padding="16"
       HasShadow="False">

                    <VerticalStackLayout Spacing="12">
                        <Label Text="Recent Reports"
               FontSize="16"
               FontAttributes="Bold"
               TextColor="#1A1A1A"/>

                        <CollectionView x:Name="RecentReportsCollection"
                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame BackgroundColor="#F7F4F4"
                           CornerRadius="12"
                           Padding="14,12"
                           HasShadow="False"
                           Margin="0,0,0,8">

                                        <!-- Main Grid: Image | Content -->
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">

                                            <!-- Left Side: Square Image -->
                                            <Frame Grid.Column="0"
                                   WidthRequest="90"
                                   HeightRequest="90"
                                   CornerRadius="10"
                                   Padding="0"
                                   HasShadow="False"
                                   IsClippedToBounds="True"
                                   VerticalOptions="Center">
                                                <Image Source="{Binding ReportImage}"
                                       Aspect="AspectFill"
                                       WidthRequest="90"
                                       HeightRequest="90"/>
                                            </Frame>






                                            <!-- Right Side: Original Content -->
                                            <Grid Grid.Column="1" 
                                  ColumnDefinitions="*,Auto" 
                                  RowDefinitions="Auto,Auto,Auto">

                                                <!-- Name + Badge -->
                                                <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="8">
                                                    <Label Text="{Binding Name}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#1A1A1A"
                                           VerticalOptions="Center"/>
                                                    <Frame Padding="8,3"
                                           CornerRadius="20"
                                           BackgroundColor="{Binding BadgeColor}"
                                           HasShadow="False">
                                                        <Label Text="{Binding RType}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="White"/>
                                                    </Frame>
                                                </HorizontalStackLayout>

                                                <!-- Status Button -->
                                                <Frame Grid.Row="0" Grid.Column="1"
                                       Grid.RowSpan="2"
                                       BackgroundColor="#D6E4FF"
                                       CornerRadius="20"
                                       Padding="14,6"
                                       HasShadow="False"
                                       VerticalOptions="Center">
                                                    <Label Text="Status"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#2563EB"/>
                                                </Frame>

                                                <!-- Description -->
                                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="{Binding Description}"
                                       FontSize="12"
                                       TextColor="#555"
                                       Margin="0,2,0,0"/>

                                                <!-- Time -->
                                                <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Spacing="4" Margin="0,4,0,0">
                                                    <Label Text="🕐"
                                           FontSize="11"
                                           TextColor="#999"
                                           VerticalOptions="Center"/>
                                                    <Label Text="{Binding TimeAgo}"
                                           FontSize="11"
                                           TextColor="#999"
                                           VerticalOptions="Center"/>
                                                </HorizontalStackLayout>

                                            </Grid>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Frame>


                <!-- Bottom Spacing -->
                <BoxView HeightRequest="20" BackgroundColor="Transparent"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation Bar -->
        <Grid Grid.Row="2" 
              BackgroundColor="White"
              HeightRequest="70"
              ColumnDefinitions="*,*,*,*,*"
              Padding="0,10">

            <!-- Home -->
            <VerticalStackLayout Grid.Column="0" 
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="Images/home.png"
                       WidthRequest="28"
                       HeightRequest="33"
                       HorizontalOptions="Center"/>
                <Label Text="Home" FontSize="11" TextColor="#8B0000" FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Report -->
            <VerticalStackLayout Grid.Column="1" 
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="Images/report.png"
                       WidthRequest="28"
                       HeightRequest="33"
                       HorizontalOptions="Center"/>
                <Label Text="Report" FontSize="11" TextColor="#666" HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Receive -->
            <VerticalStackLayout Grid.Column="2" 
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="Images/box.png"
                       WidthRequest="28"
                       HeightRequest="33"
                       HorizontalOptions="Center"/>
                <Label Text="Receive" FontSize="11" TextColor="#666" HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReceiveTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- News -->
            <VerticalStackLayout Grid.Column="3" 
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="Images/notif.png"
                       WidthRequest="28"
                       HeightRequest="33"
                       HorizontalOptions="Center"/>
                <Label Text="News" FontSize="11" TextColor="#666" HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNewsTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Logout -->
            <VerticalStackLayout Grid.Column="4" 
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="Images/logout.png"
                       WidthRequest="28"
                       HeightRequest="33"
                       HorizontalOptions="Center">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoutClicked"/>
                    </Image.GestureRecognizers>
                </Image>
                <Label Text="Logout" FontSize="11" TextColor="#666" HorizontalOptions="Center"/>
            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>
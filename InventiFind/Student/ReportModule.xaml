<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.ReportModule"
             Title="Report Item"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F2F4F7">

    <Grid RowDefinitions="*,Auto">

        <!-- ── SCROLLABLE CONTENT ──────────────────────────────────────── -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Grid HeightRequest="110" BackgroundColor="#C8102E">
                    <Label Text="Report Item"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Margin="0,20,0,0"/>
                </Grid>

                <!-- Form -->
                <VerticalStackLayout Padding="18,22,18,24" Spacing="18">

                    <!-- Report Type toggle -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Report Type"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#111827"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Frame x:Name="LostFrame"
                                   Grid.Column="0"
                                   BackgroundColor="#C8102E"
                                   CornerRadius="12"
                                   Padding="12,11"
                                   HasShadow="False"
                                   BorderColor="#C8102E">
                                <Label Text="I Lost Something"
                                       FontSize="14"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       FontAttributes="Bold"/>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLostSomethingTapped"/>
                                </Frame.GestureRecognizers>
                            </Frame>
                            <Frame x:Name="FoundFrame"
                                   Grid.Column="1"
                                   BackgroundColor="White"
                                   CornerRadius="12"
                                   Padding="12,11"
                                   HasShadow="False"
                                   BorderColor="#E5E7EB">
                                <Label Text="I Found Something"
                                       FontSize="14"
                                       TextColor="#9CA3AF"
                                       HorizontalOptions="Center"/>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFoundSomethingTapped"/>
                                </Frame.GestureRecognizers>
                            </Frame>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Item Name -->
                    <VerticalStackLayout Spacing="7">
                        <Label Text="Item Name"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#111827"/>
                        <Frame BackgroundColor="White"
                               CornerRadius="12"
                               Padding="14,0"
                               HasShadow="False"
                               BorderColor="#E5E7EB">
                            <Entry x:Name="ItemNameEntry"
                                   Placeholder="e.g., iPhone 14, Green Wallet"
                                   PlaceholderColor="#9CA3AF"
                                   TextColor="#111827"
                                   FontSize="14"
                                   HeightRequest="48"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Category -->
                    <VerticalStackLayout Spacing="7">
                        <Label Text="Category"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#111827"/>
                        <Frame BackgroundColor="White"
                               CornerRadius="12"
                               Padding="14,0"
                               HasShadow="False"
                               BorderColor="#E5E7EB">
                            <Picker x:Name="CategoryPicker"
                                    Title="Select a category"
                                    TitleColor="#9CA3AF"
                                    TextColor="#111827"
                                    FontSize="14"
                                    HeightRequest="48">
                                <Picker.Items>
                                    <x:String>Phone</x:String>
                                    <x:String>Wallet</x:String>
                                    <x:String>ID</x:String>
                                    <x:String>Watch</x:String>
                                    <x:String>Keys</x:String>
                                    <x:String>Others</x:String>
                                </Picker.Items>
                            </Picker>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Description -->
                    <VerticalStackLayout Spacing="7">
                        <Label Text="Description"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#111827"/>
                        <Frame BackgroundColor="White"
                               CornerRadius="12"
                               Padding="14,10"
                               HasShadow="False"
                               BorderColor="#E5E7EB"
                               HeightRequest="100">
                            <Editor x:Name="DescriptionEditor"
                                    Placeholder="Color, brand, distinguishing features…"
                                    PlaceholderColor="#9CA3AF"
                                    TextColor="#111827"
                                    FontSize="14"
                                    AutoSize="TextChanges"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Location -->
                    <VerticalStackLayout Spacing="7">
                        <Label Text="📍  Location"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#111827"/>
                        <Frame BackgroundColor="White"
                               CornerRadius="12"
                               Padding="14,0"
                               HasShadow="False"
                               BorderColor="#E5E7EB">
                            <Entry x:Name="LocationEntry"
                                   Placeholder="Where was it lost / found?"
                                   PlaceholderColor="#9CA3AF"
                                   TextColor="#111827"
                                   FontSize="14"
                                   HeightRequest="48"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Date -->
                    <VerticalStackLayout Spacing="7">
                        <Label Text="📅  Date"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#111827"/>
                        <Frame BackgroundColor="White"
                               CornerRadius="12"
                               Padding="14,0"
                               HasShadow="False"
                               BorderColor="#E5E7EB">
                            <DatePicker x:Name="DatePicker"
                                        FontSize="14"
                                        TextColor="#111827"
                                        HeightRequest="48"
                                        Format="MM/dd/yyyy"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Upload -->
                    <VerticalStackLayout Spacing="7">
                        <Label Text="Upload Image"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#111827"/>
                        <Frame x:Name="UploadFrame"
                               BackgroundColor="White"
                               CornerRadius="12"
                               Padding="20,22"
                               HasShadow="False"
                               BorderColor="#E5E7EB">
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Label x:Name="UploadIcon"
                                       Text="☁️"
                                       FontSize="36"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="UploadText"
                                       Text="Tap to upload"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#374151"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="UploadSubtext"
                                       Text="PNG, JPG up to 10 MB"
                                       FontSize="12"
                                       TextColor="#9CA3AF"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnUploadTapped"/>
                            </Frame.GestureRecognizers>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Submit -->
                    <Frame BackgroundColor="#C8102E"
                           CornerRadius="12"
                           Padding="0,16"
                           HasShadow="False"
                           Margin="0,6,0,0">
                        <Label Text="Submit Report"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSubmitTapped"/>
                        </Frame.GestureRecognizers>
                    </Frame>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ── BOTTOM NAV ─────────────────────────────────────────────── -->
        <Grid Grid.Row="1"
              BackgroundColor="White"
              HeightRequest="70"
              ColumnDefinitions="*,*,*,*,*"
              Padding="0,10">

            <!-- Home -->
            <VerticalStackLayout Grid.Column="0"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="home.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Home" FontSize="11" TextColor="#9CA3AF"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Report (Active) -->
            <VerticalStackLayout Grid.Column="1"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="report.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Report" FontSize="11" TextColor="#C8102E" FontAttributes="Bold"/>
                <BoxView HeightRequest="2" BackgroundColor="#C8102E"
                         CornerRadius="1" Margin="0,-2,0,0"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Receive -->
            <VerticalStackLayout Grid.Column="2"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="box.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Receive" FontSize="11" TextColor="#9CA3AF"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReceiveTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- News -->
            <VerticalStackLayout Grid.Column="3"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="notif.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="News" FontSize="11" TextColor="#9CA3AF"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNewsTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Logout -->
            <VerticalStackLayout Grid.Column="4"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="gear.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Settings" FontSize="11" TextColor="#9CA3AF"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>

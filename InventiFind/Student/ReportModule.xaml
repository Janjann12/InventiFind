<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.ReportModule"
             Title="Report Item"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0E6E6">

    <Grid RowDefinitions="*,Auto">

        <!-- Scrollable Content - Takes all available space (Row 0) -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Header with Red Background -->
                <Grid HeightRequest="120" BackgroundColor="#B71C1C">
                    <Label Text="Report Item" FontSize="28" FontAttributes="Bold" 
                           TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>

                <!-- Form Content -->
                <VerticalStackLayout Padding="20,25,20,20" Spacing="20">

                    <!-- Report Type with x:Name for toggle -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Report Type" FontSize="16" FontAttributes="Bold" TextColor="#1a1a1a"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                            <!-- I Lost Something -->
                            <Frame x:Name="LostFrame" Grid.Column="0" BackgroundColor="#FFE4E1" 
                                   CornerRadius="10" Padding="12,10" HasShadow="False" BorderColor="#B71C1C">
                                <Label Text="I Lost Something" FontSize="14" TextColor="#B71C1C" 
                                       HorizontalOptions="Center" FontAttributes="Bold"/>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLostSomethingTapped"/>
                                </Frame.GestureRecognizers>
                            </Frame>
                            <!-- I Found Something -->
                            <Frame x:Name="FoundFrame" Grid.Column="1" BackgroundColor="White" 
                                   CornerRadius="10" Padding="12,10" HasShadow="False" BorderColor="#CCCCCC">
                                <Label Text="I Found Something" FontSize="14" TextColor="#999999" 
                                       HorizontalOptions="Center"/>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFoundSomethingTapped"/>
                                </Frame.GestureRecognizers>
                            </Frame>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Item Name -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Item Name"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#1a1a1a"/>
                        <Frame BackgroundColor="White"
                               CornerRadius="10"
                               Padding="12,0"
                               HasShadow="False"
                               BorderColor="#DDDDDD">
                            <Entry x:Name="ItemNameEntry"
                                   Placeholder="e.g., iPhone 14, Green Wallet"
                                   PlaceholderColor="#AAAAAA"
                                   TextColor="#333333"
                                   FontSize="14"
                                   HeightRequest="45"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Category -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Category"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#1a1a1a"/>
                        <Frame BackgroundColor="White"
                               CornerRadius="10"
                               Padding="12,0"
                               HasShadow="False"
                               BorderColor="#DDDDDD">
                            <Picker x:Name="CategoryPicker"
                                    Title="Select a category"
                                    TextColor="#333333"
                                    FontSize="14"
                                    HeightRequest="45">
                                <Picker.Items>
                                    <x:String>Phone</x:String>
                                    <x:String>Wallet</x:String>
                                    <x:String>ID</x:String>
                                    <x:String>Watch</x:String>
                                    <x:String>Keys</x:String>
                                    <x:String>Others</x:String>
                                </Picker.Items>
                            </Picker>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Description -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Description"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#1a1a1a"/>
                        <Frame BackgroundColor="White"
                               CornerRadius="10"
                               Padding="12"
                               HasShadow="False"
                               BorderColor="#DDDDDD"
                               HeightRequest="100">
                            <Editor x:Name="DescriptionEditor"
                                    Placeholder="Provide a detailed description (color, brand, etc.)"
                                    PlaceholderColor="#AAAAAA"
                                    TextColor="#333333"
                                    FontSize="14"
                                    AutoSize="TextChanges"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Location -->
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="5">
                            <Label Text="📍" FontSize="16"/>
                            <Label Text="Location"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#1a1a1a"/>
                        </HorizontalStackLayout>
                        <Frame BackgroundColor="White"
                               CornerRadius="10"
                               Padding="12,0"
                               HasShadow="False"
                               BorderColor="#DDDDDD">
                            <Entry x:Name="LocationEntry"
                                   Placeholder="Where was it lost/found?"
                                   PlaceholderColor="#AAAAAA"
                                   TextColor="#333333"
                                   FontSize="14"
                                   HeightRequest="45"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Date -->
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="5">
                            <Label Text="📅" FontSize="16"/>
                            <Label Text="Date"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#1a1a1a"/>
                        </HorizontalStackLayout>
                        <Frame BackgroundColor="White"
                               CornerRadius="10"
                               Padding="12,0"
                               HasShadow="False"
                               BorderColor="#DDDDDD">
                            <DatePicker x:Name="DatePicker"
                                        FontSize="14"
                                        TextColor="#333333"
                                        HeightRequest="45"
                                        Format="MM/dd/yyyy"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Upload Images/Files -->
                    <VerticalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="5">
                            <Label Text="☁️" FontSize="16"/>
                            <Label Text="Upload Images/Files"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#1a1a1a"/>
                        </HorizontalStackLayout>

                        <Frame x:Name="UploadFrame"
                               BackgroundColor="White"
                               CornerRadius="10"
                               Padding="20"
                               HasShadow="False"
                               BorderColor="#AAAAAA">
                            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label x:Name="UploadIcon"
                                       Text="☁️"
                                       FontSize="40"
                                       TextColor="#999999"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="UploadText"
                                       Text="Click to upload images or files"
                                       FontSize="14"
                                       TextColor="#1a1a1a"
                                       HorizontalOptions="Center"
                                       FontAttributes="Bold"/>
                                <Label x:Name="UploadSubtext"
                                       Text="PNG, JPG, PDF up to 10mb"
                                       FontSize="12"
                                       TextColor="#999999"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnUploadTapped"/>
                            </Frame.GestureRecognizers>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Submit Button - INSIDE ScrollView, under Upload, scrolls with content -->
                    <Frame BackgroundColor="#B71C1C"
                           CornerRadius="10"
                           Padding="15"
                           HasShadow="False"
                           Margin="0,10,0,20">
                        <Label Text="Submit Report"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSubmitTapped"/>
                        </Frame.GestureRecognizers>
                    </Frame>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation Bar - Always at very bottom (Row 1) -->
        <Grid Grid.Row="1" 
              BackgroundColor="White"
              HeightRequest="70"
              ColumnDefinitions="*,*,*,*,*"
              Padding="0,10">

            <!-- Home -->
            <VerticalStackLayout Grid.Column="0" 
                         Spacing="2"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <Image Source="home.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Home" FontSize="11" TextColor="#666"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Report -->
            <VerticalStackLayout Grid.Column="1" 
                         Spacing="2"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <Image Source="report.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Home" FontSize="11" TextColor="#B71C1C"/>
                <BoxView HeightRequest="2" BackgroundColor="#B71C1C" CornerRadius="1" Margin="0,-2,0,0"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Receive (Active) -->
            <VerticalStackLayout Grid.Column="2" 
                         Spacing="2"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <Image Source="box.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Receive" FontSize="11" TextColor="#666" FontAttributes="Bold"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReceiveTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- News -->
            <VerticalStackLayout Grid.Column="3" 
                         Spacing="2"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <Image Source="notif.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="News" FontSize="11" TextColor="#666"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNewsTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Logout -->
            <VerticalStackLayout Grid.Column="4" 
                         Spacing="2"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <Image Source="logout.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Logout" FontSize="11" TextColor="#666"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
        </Grid>

    </Grid>

</ContentPage>
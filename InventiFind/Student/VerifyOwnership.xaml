<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.VerifyOwnership"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F0F0">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0"
                BackgroundColor="#B71C1C"
                StrokeThickness="0"
                Padding="0,45,0,20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,25,25"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,0">

                <!-- Back -->
                <Label Grid.Column="0"
                       Text="←"
                       FontSize="22"
                       TextColor="White"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Label.GestureRecognizers>
                </Label>

                <Label Grid.Column="1"
                       Text="Verify Ownership"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>

            </Grid>
        </Border>

        <!-- Scrollable Form -->
        <ScrollView Grid.Row="1" Padding="18,20">
            <VerticalStackLayout Spacing="16">

                <!-- Info banner -->
                <Border BackgroundColor="#D6EAF8"
                        Stroke="#5DADE2"
                        StrokeThickness="1"
                        Padding="14">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Ownership Verification"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#2E86AB"/>
                        <Label Text="Fill in the details below to prove you are the rightful owner of this item. Your submission will be reviewed by staff."
                               FontSize="13"
                               TextColor="#2E86AB"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Match summary card -->
                <Border BackgroundColor="White"
                        Stroke="#E0E0E0"
                        StrokeThickness="1"
                        Padding="14">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Matched Item"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="#888"/>
                        <Label x:Name="ItemNameLabel"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A"/>
                        <Label x:Name="CategoryLabel"
                               FontSize="13"
                               TextColor="#555"/>
                        <Label x:Name="MatchIdLabel"
                               FontSize="11"
                               TextColor="#AAA"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Full Name -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Full Name"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#444"/>
                    <Border BackgroundColor="White"
                            Stroke="#E0E0E0"
                            StrokeThickness="1"
                            Padding="14,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                      
                    </Border>
                </VerticalStackLayout>

                <!-- Item Description -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Item Description"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#444"/>
                    <Label Text="Describe the item in detail — color, brand, markings, contents, etc."
                           FontSize="12"
                           TextColor="#888"/>
                    <Border BackgroundColor="White"
                            Stroke="#E0E0E0"
                            StrokeThickness="1"
                            Padding="14,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Editor x:Name="ItemDescriptionEditor"
                                Placeholder="e.g. Black leather wallet with a small scratch on the left corner, contains student ID..."
                                FontSize="14"
                                PlaceholderColor="#BBB"
                                TextColor="#1A1A1A"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="100"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Date Lost -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Date Lost"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#444"/>
                    <Border BackgroundColor="White"
                            Stroke="#E0E0E0"
                            StrokeThickness="1"
                            Padding="14,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <DatePicker x:Name="DateLostPicker"
            Format="MMMM dd, yyyy"
            FontSize="14"
            TextColor="#1A1A1A"/>

                    </Border>
                </VerticalStackLayout>

                <!-- Proof Photo -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Proof Photo"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#444"/>
                    <Label Text="Upload a photo that helps prove ownership (e.g. a photo of you with the item, receipt, etc.)"
                           FontSize="12"
                           TextColor="#888"/>

                    <!-- Upload button -->
                    <Border x:Name="PhotoPickerBorder"
                            BackgroundColor="White"
                            Stroke="#E0E0E0"
                            StrokeThickness="1"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="14,18" Spacing="6">
                            <Label Text="📎"
                                   FontSize="28"
                                   HorizontalOptions="Center"/>
                            <Label Text="Tap to choose a photo"
                                   FontSize="13"
                                   TextColor="#888"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPickPhotoTapped"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Preview (hidden until photo picked) -->
                    <Border x:Name="PhotoPreviewBorder"
                            IsVisible="False"
                            BackgroundColor="White"
                            Stroke="#E0E0E0"
                            StrokeThickness="1"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Grid RowDefinitions="Auto,Auto">
                            <Image x:Name="PhotoPreviewImage"
                                   Grid.Row="0"
                                   HeightRequest="200"
                                   Aspect="AspectFill"/>
                            <Button Grid.Row="1"
                                    Text="Remove photo"
                                    FontSize="13"
                                    TextColor="#B71C1C"
                                    BackgroundColor="Transparent"
                                    Clicked="OnRemovePhotoClicked"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Bottom padding -->
                <BoxView HeightRequest="20" Color="Transparent"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Submit Button -->
        <Border Grid.Row="2"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="18,12,18,30"
                Shadow="{Shadow Brush=#20000000, Offset='0,-2', Radius=4}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0"/>
            </Border.StrokeShape>
            <Button x:Name="SubmitBtn"
                    Text="Submit Verification"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="White"
                    BackgroundColor="#B71C1C"
                    CornerRadius="12"
                    HeightRequest="52"
                    Clicked="OnSubmitClicked"/>
        </Border>

    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.ReceiveModule"
             Shell.NavBarIsVisible="False"
             Title="ReceiveModule"
             BackgroundColor="#F2F4F7">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── HEADER ─────────────────────────────────────────────────── -->
        <Grid Grid.Row="0"
              BackgroundColor="#C8102E"
              Padding="20,44,20,24">
            <Label Text="Receive Items"
                   TextColor="White"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>
        </Grid>

        <!-- ── MAIN CONTENT ───────────────────────────────────────────── -->
        <ScrollView Grid.Row="1" Padding="16,16,16,8">
            <VerticalStackLayout Spacing="14">

                <!-- How to Claim -->
                <Frame BackgroundColor="White"
                       CornerRadius="16"
                       Padding="16,14"
                       HasShadow="False"
                       BorderColor="#E5E7EB">
                    <VerticalStackLayout Spacing="10">

                        <Label Text="How to Claim Your Item"
                               TextColor="#111827"
                               FontSize="15"
                               FontAttributes="Bold"/>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="#F3F4F6"
                                 Margin="0,0,0,2"/>

                        <Grid ColumnDefinitions="28,*" ColumnSpacing="10" RowSpacing="10"
                              RowDefinitions="Auto,Auto,Auto,Auto">

                            <!-- Step 1 -->
                            <Frame Grid.Row="0" Grid.Column="0"
                                   BackgroundColor="#FEE2E2"
                                   CornerRadius="14"
                                   Padding="0"
                                   HasShadow="False"
                                   WidthRequest="28" HeightRequest="28">
                                <Label Text="1" FontSize="12" FontAttributes="Bold"
                                       TextColor="#C8102E"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Frame>
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="Visit the location shown on the card"
                                   TextColor="#374151" FontSize="13"
                                   VerticalOptions="Center"/>

                            <!-- Step 2 -->
                            <Frame Grid.Row="1" Grid.Column="0"
                                   BackgroundColor="#FEE2E2"
                                   CornerRadius="14"
                                   Padding="0"
                                   HasShadow="False"
                                   WidthRequest="28" HeightRequest="28">
                                <Label Text="2" FontSize="12" FontAttributes="Bold"
                                       TextColor="#C8102E"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Frame>
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="Bring a valid ID for verification"
                                   TextColor="#374151" FontSize="13"
                                   VerticalOptions="Center"/>

                            <!-- Step 3 -->
                            <Frame Grid.Row="2" Grid.Column="0"
                                   BackgroundColor="#FEE2E2"
                                   CornerRadius="14"
                                   Padding="0"
                                   HasShadow="False"
                                   WidthRequest="28" HeightRequest="28">
                                <Label Text="3" FontSize="12" FontAttributes="Bold"
                                       TextColor="#C8102E"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Frame>
                            <Label Grid.Row="2" Grid.Column="1"
                                   Text="Provide your item verification code"
                                   TextColor="#374151" FontSize="13"
                                   VerticalOptions="Center"/>

                            <!-- Step 4 -->
                            <Frame Grid.Row="3" Grid.Column="0"
                                   BackgroundColor="#FEE2E2"
                                   CornerRadius="14"
                                   Padding="0"
                                   HasShadow="False"
                                   WidthRequest="28" HeightRequest="28">
                                <Label Text="4" FontSize="12" FontAttributes="Bold"
                                       TextColor="#C8102E"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Frame>
                            <Label Grid.Row="3" Grid.Column="1"
                                   Text="Sign the release form"
                                   TextColor="#374151" FontSize="13"
                                   VerticalOptions="Center"/>

                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Match Cards (dynamically added in code-behind) -->
                <VerticalStackLayout x:Name="MatchesStack" Spacing="12"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── BOTTOM NAV ─────────────────────────────────────────────── -->
        <Grid Grid.Row="2"
              BackgroundColor="White"
              HeightRequest="70"
              ColumnDefinitions="*,*,*,*,*"
              Padding="0,10">

            <!-- Home -->
            <VerticalStackLayout Grid.Column="0"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="home.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Home" FontSize="11" TextColor="#9CA3AF"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Report -->
            <VerticalStackLayout Grid.Column="1"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="report.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Report" FontSize="11" TextColor="#9CA3AF"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Receive (Active) -->
            <VerticalStackLayout Grid.Column="2"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="box.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Receive" FontSize="11" TextColor="#C8102E" FontAttributes="Bold"/>
                <BoxView HeightRequest="2" BackgroundColor="#C8102E"
                         CornerRadius="1" Margin="0,-2,0,0"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReceiveTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- News -->
            <VerticalStackLayout Grid.Column="3"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="notif.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="News" FontSize="11" TextColor="#9CA3AF"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNewsTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Logout -->
            <VerticalStackLayout Grid.Column="4"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="logout.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Logout" FontSize="11" TextColor="#9CA3AF"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>

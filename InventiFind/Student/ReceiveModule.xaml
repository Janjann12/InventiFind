<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.ReceiveModule"
             Shell.NavBarIsVisible="False"
             Title="ReceiveModule"
             BackgroundColor="#F5F0F0">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0"
                BackgroundColor="#B71C1C"
                StrokeThickness="0"
                Padding="0,25,0,20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,25,25"/>
            </Border.StrokeShape>
            <Label Text="Receive Items"
                   TextColor="White"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>
        </Border>

        <!-- Main Content -->
        <ScrollView Grid.Row="1" Padding="15,20">
            <VerticalStackLayout Spacing="15">

                <!-- How to Claim Box -->
                <Border BackgroundColor="#D6EAF8"
                        Stroke="#5DADE2"
                        StrokeThickness="1"
                        Padding="15"
                        Margin="0,0,0,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="5">
                        <Label Text="How to Claim Your Item"
                               TextColor="#2E86AB"
                               FontSize="16"
                               FontAttributes="Bold"/>
                        <Label Text="1. Visit the location shown below"
                               TextColor="#2E86AB"
                               FontSize="13"/>
                        <Label Text="2. Bring a valid ID for verification"
                               TextColor="#2E86AB"
                               FontSize="13"/>
                        <Label Text="3. Provide item verification code"
                               TextColor="#2E86AB"
                               FontSize="13"/>
                        <Label Text="4. Sign the release form"
                               TextColor="#2E86AB"
                               FontSize="13"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Match Cards (dynamically added in code-behind) -->
                <VerticalStackLayout x:Name="MatchesStack" Spacing="12"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <Grid Grid.Row="2"
              BackgroundColor="White"
              HeightRequest="70"
              ColumnDefinitions="*,*,*,*,*"
              Padding="0,10"
              Shadow="{Shadow Brush=#20000000, Offset='0,-2', Radius=4}">

            <!-- Home -->
            <VerticalStackLayout Grid.Column="0"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="home.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Home" FontSize="11" TextColor="#666"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Report -->
            <VerticalStackLayout Grid.Column="1"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="report.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Report" FontSize="11" TextColor="#666"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Receive (Active) -->
            <VerticalStackLayout Grid.Column="2"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="box.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Receive" FontSize="11" TextColor="#B71C1C" FontAttributes="Bold"/>
                <BoxView HeightRequest="2" BackgroundColor="#B71C1C" CornerRadius="1" Margin="0,-2,0,0"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReceiveTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- News -->
            <VerticalStackLayout Grid.Column="3"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="notif.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="News" FontSize="11" TextColor="#666"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNewsTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Logout -->
            <VerticalStackLayout Grid.Column="4"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="logout.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Logout" FontSize="11" TextColor="#666"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

        </Grid>
    </Grid>

</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.SurrenderedItemPage"
             BackgroundColor="#F2F4F7"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="#C8102E"
              Padding="20,40,20,24"
              HeightRequest="140">

            <VerticalStackLayout Spacing="2">
                <Label Text="Surrendered Items"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="White"/>
                <Label Text="Open lost and found reports"
                       FontSize="13"
                       TextColor="#FDECEC"/>
            </VerticalStackLayout>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*">

            <!-- STATS -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="8"
                  Margin="12,12,12,6">

                <Frame Grid.Column="0"
                       BackgroundColor="White"
                       CornerRadius="16"
                       Padding="10"
                       HeightRequest="82"
                       HasShadow="False"
                       BorderColor="#E5E7EB">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="0">
                        <Label x:Name="UnclaimedTotalLabel"
                               Text="0"
                               FontSize="25"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               HorizontalOptions="Center"/>
                        <Label Text="Total"
                               FontSize="11"
                               TextColor="#6B7280"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1"
                       BackgroundColor="White"
                       CornerRadius="16"
                       Padding="10"
                       HeightRequest="82"
                       HasShadow="False"
                       BorderColor="#E5E7EB">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="0">
                        <Label x:Name="UnclaimedLostLabel"
                               Text="0"
                               FontSize="25"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               HorizontalOptions="Center"/>
                        <Label Text="Lost"
                               FontSize="11"
                               TextColor="#6B7280"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="2"
                       BackgroundColor="White"
                       CornerRadius="16"
                       Padding="10"
                       HeightRequest="82"
                       HasShadow="False"
                       BorderColor="#E5E7EB">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="0">
                        <Label x:Name="UnclaimedFoundLabel"
                               Text="0"
                               FontSize="25"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               HorizontalOptions="Center"/>
                        <Label Text="Found"
                               FontSize="11"
                               TextColor="#6B7280"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>

            </Grid>

            <!-- FILTER -->
            <Grid Grid.Row="1"
                  ColumnDefinitions="*,*,*,*"
                  ColumnSpacing="8"
                  Margin="12,4,12,6">

                <Frame x:Name="AllItemsFrame"
                       Grid.Column="0"
                       BackgroundColor="White"
                       CornerRadius="16"
                       HeightRequest="58"
                       Padding="4"
                       HasShadow="False"
                       BorderColor="#E5E7EB">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="all"/>
                    </Frame.GestureRecognizers>
                    <Label x:Name="AllItemsLabel"
                           Text="All"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Frame>

                <Frame x:Name="LostItemsFrame"
                       Grid.Column="1"
                       BackgroundColor="White"
                       CornerRadius="16"
                       HeightRequest="58"
                       Padding="4"
                       HasShadow="False"
                       BorderColor="#E5E7EB">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="lost"/>
                    </Frame.GestureRecognizers>
                    <Label x:Name="LostItemsLabel"
                           Text="Lost"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Frame>

                <Frame x:Name="FoundItemsFrame"
                       Grid.Column="2"
                       BackgroundColor="White"
                       CornerRadius="16"
                       HeightRequest="58"
                       Padding="4"
                       HasShadow="False"
                       BorderColor="#E5E7EB">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="found"/>
                    </Frame.GestureRecognizers>
                    <Label x:Name="FoundItemsLabel"
                           Text="Found"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Frame>

                <Frame Grid.Column="3"
                       BackgroundColor="White"
                       CornerRadius="16"
                       HeightRequest="58"
                       Padding="6,0"
                       HasShadow="False"
                       BorderColor="#E5E7EB">

                    <Picker x:Name="StatusPicker"
                            Title="Status"
                            FontSize="11"
                            FontAttributes="Bold"
                            TextColor="#111827"
                            TitleColor="#6B7280"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            SelectedIndexChanged="OnStatusPickerChanged"/>
                </Frame>

            </Grid>

            <!-- LIST -->
            <CollectionView Grid.Row="2"
                            x:Name="ItemsCollection"
                            SelectionMode="Single"
                            SelectionChanged="OnItemSelected"
                            Margin="12,4,12,0">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="6"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="White"
                               CornerRadius="16"
                               Padding="14"
                               BorderColor="#E5E7EB"
                               HeightRequest="100"
                               HasShadow="False"
                               Margin="0,0,0,6">

                            <Grid ColumnDefinitions="58,*,Auto"
                                  RowDefinitions="Auto,Auto,Auto"
                                  ColumnSpacing="12"
                                  RowSpacing="4">

                                <Frame Grid.Column="0"
                                       Grid.RowSpan="3"
                                       BackgroundColor="#F3F4F6"
                                       WidthRequest="55"
                                       HeightRequest="55"
                                       CornerRadius="14"
                                       Padding="10"
                                       HasShadow="False"
                                       VerticalOptions="Center">

                                    <Image Source="{Binding CategoryIcon}"
                                           Aspect="AspectFit"/>
                                </Frame>

                                <Label Grid.Column="1"
                                       Grid.Row="0"
                                       Text="{Binding Name}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#111827"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1"/>

                                <Frame Grid.Column="2"
                                       Grid.Row="0"
                                       BackgroundColor="{Binding StatusBadgeColor}"
                                       CornerRadius="14"
                                       Padding="8,3"
                                       HasShadow="False">
                                    <Label Text="{Binding Status}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="White"/>
                                </Frame>

                                <Label Grid.Column="1"
                                       Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding ReporterName}"
                                       FontSize="13"
                                       TextColor="#6B7280"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1"/>

                                <Label Grid.Column="1"
                                       Grid.Row="2"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding DateString}"
                                       FontSize="12"
                                       TextColor="#9CA3AF"/>

                            </Grid>

                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </Grid>

        <!-- NAVIGATION BAR -->
        <Grid Grid.Row="2"
              BackgroundColor="White"
              ColumnDefinitions="*,*,*,*"
              HeightRequest="70"
              Padding="0,10">

            <!-- Dashboard -->
            <VerticalStackLayout Grid.Column="0"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="home.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Dashboard"
                       FontSize="11"
                       TextColor="#9CA3AF"
                       HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDashboardTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Reports Active -->
            <VerticalStackLayout Grid.Column="1"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="report.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Reports"
                       FontSize="11"
                       TextColor="#C8102E"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <BoxView HeightRequest="2"
                         WidthRequest="28"
                         BackgroundColor="#C8102E"
                         CornerRadius="1"
                         Margin="0,-2,0,0"/>
            </VerticalStackLayout>

            <!-- Verify -->
            <VerticalStackLayout Grid.Column="2"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="notif.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Verify"
                       FontSize="11"
                       TextColor="#9CA3AF"
                       HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnVerifyTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Returned -->
            <VerticalStackLayout Grid.Column="3"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="box.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Returned"
                       FontSize="11"
                       TextColor="#9CA3AF"
                       HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReturnedTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.SurrenderedItemPage"
             BackgroundColor="#F0EBEB"
             Shell.NavBarIsVisible="False">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" IsEnabled="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0"
              BackgroundColor="#8B0000"
              Padding="20,50,20,22">
            <VerticalStackLayout Spacing="4">
                <Label Text="Surrendered Items"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="White"/>
                <Label Text="Open lost and found reports"
                       FontSize="13"
                       TextColor="#F6DADA"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*">

            <!-- Summary Cards Row -->
            <ScrollView Grid.Row="0"
                        Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never"
                        Margin="12,14,12,4">
                <HorizontalStackLayout Spacing="10">

                    <Frame BackgroundColor="White"
                           CornerRadius="18"
                           Padding="18,14"
                           HasShadow="False"
                           BorderColor="#E6E1E1"
                           WidthRequest="145">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label x:Name="UnclaimedTotalLabel"
                                   Text="0"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="#1A1A1A"
                                   HorizontalOptions="Center"/>
                            <Label Text="Total Items"
                                   FontSize="12"
                                   TextColor="#888"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame BackgroundColor="White"
                           CornerRadius="18"
                           Padding="18,14"
                           HasShadow="False"
                           BorderColor="#E6E1E1"
                           WidthRequest="145">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label x:Name="UnclaimedLostLabel"
                                   Text="0"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="#1A1A1A"
                                   HorizontalOptions="Center"/>
                            <Label Text="Lost Items"
                                   FontSize="12"
                                   TextColor="#888"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame BackgroundColor="White"
                           CornerRadius="18"
                           Padding="18,14"
                           HasShadow="False"
                           BorderColor="#E6E1E1"
                           WidthRequest="145">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label x:Name="UnclaimedFoundLabel"
                                   Text="0"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="#1A1A1A"
                                   HorizontalOptions="Center"/>
                            <Label Text="Found Items"
                                   FontSize="12"
                                   TextColor="#888"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                </HorizontalStackLayout>
            </ScrollView>

            <!-- Filter Buttons Row -->
            <ScrollView Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never"
                        Margin="12,4,12,0">
                <HorizontalStackLayout Spacing="8">

                    <Frame x:Name="AllItemsFrame"
                           BackgroundColor="White"
                           CornerRadius="22"
                           Padding="16,9"
                           HasShadow="False"
                           BorderColor="#E6E1E1">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="all"/>
                        </Frame.GestureRecognizers>
                        <Label x:Name="AllItemsLabel"
                               Text="All Items"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A"/>
                    </Frame>

                    <Frame x:Name="LostItemsFrame"
                           BackgroundColor="White"
                           CornerRadius="22"
                           Padding="16,9"
                           HasShadow="False"
                           BorderColor="#E6E1E1">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="lost"/>
                        </Frame.GestureRecognizers>
                        <Label x:Name="LostItemsLabel"
                               Text="Lost Items"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A"/>
                    </Frame>

                    <Frame x:Name="FoundItemsFrame"
                           BackgroundColor="White"
                           CornerRadius="22"
                           Padding="16,9"
                           HasShadow="False"
                           BorderColor="#E6E1E1">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="found"/>
                        </Frame.GestureRecognizers>
                        <Label x:Name="FoundItemsLabel"
                               Text="Found Items"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A"/>
                    </Frame>

                    <Frame BackgroundColor="White"
                           CornerRadius="22"
                           Padding="10,0"
                           HasShadow="False"
                           BorderColor="#E6E1E1"
                           MinimumWidthRequest="135">
                        <Picker x:Name="StatusPicker"
                                Title="All Status"
                                FontSize="13"
                                FontAttributes="Bold"
                                TextColor="#1A1A1A"
                                TitleColor="#1A1A1A"
                                SelectedIndexChanged="OnStatusPickerChanged"/>
                    </Frame>

                </HorizontalStackLayout>
            </ScrollView>

            <!-- Items List -->
            <CollectionView Grid.Row="2"
                            x:Name="ItemsCollection"
                            SelectionMode="None"
                            Margin="12,12,12,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="White"
                               CornerRadius="18"
                               Padding="14"
                               HasShadow="False"
                               BorderColor="#E6E1E1"
                               Margin="0,0,0,12">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  RowDefinitions="Auto,Auto,Auto"
                                  ColumnSpacing="12"
                                  RowSpacing="3">

                                <!-- Icon -->
                                <Frame Grid.Column="0"
                                       Grid.RowSpan="3"
                                       BackgroundColor="#8B0000"
                                       CornerRadius="14"
                                       Padding="0"
                                       HasShadow="False"
                                       WidthRequest="70"
                                       HeightRequest="70"
                                       VerticalOptions="Center">
                                    <Label Text="📦"
                                           FontSize="28"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>

                                <!-- Item Name -->
                                <Label Grid.Column="1"
                                       Grid.Row="0"
                                       Text="{Binding Name}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#1A1A1A"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1"/>

                                <!-- Status Badge -->
                                <Frame Grid.Column="2"
                                       Grid.Row="0"
                                       BackgroundColor="{Binding StatusBadgeColor}"
                                       CornerRadius="20"
                                       Padding="12,5"
                                       HasShadow="False"
                                       VerticalOptions="Start">
                                    <Label Text="{Binding Status}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="White"/>
                                </Frame>

                                <!-- Reporter -->
                                <Label Grid.Column="1"
                                       Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding ReporterName}"
                                       FontSize="13"
                                       TextColor="#666"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1"/>

                                <!-- Date + Location -->
                                <Grid Grid.Column="1"
                                      Grid.Row="2"
                                      Grid.ColumnSpan="2"
                                      ColumnDefinitions="Auto,*,Auto,*"
                                      ColumnSpacing="6"
                                      Margin="0,4,0,0">
                                    <Label Grid.Column="0"
                                           Text="📅"
                                           FontSize="12"
                                           TextColor="#999"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding DateString}"
                                           FontSize="12"
                                           TextColor="#777"
                                           VerticalOptions="Center"
                                           LineBreakMode="TailTruncation"/>

                                    <Label Grid.Column="2"
                                           Text="📍"
                                           FontSize="12"
                                           TextColor="#999"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="3"
                                           Text="{Binding Location}"
                                           FontSize="12"
                                           TextColor="#777"
                                           VerticalOptions="Center"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1"/>
                                </Grid>

                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="8"
                                         Margin="0,70,0,0">
                        <Label Text="📭"
                               FontSize="48"
                               HorizontalOptions="Center"/>
                        <Label Text="No surrendered items found"
                               FontSize="16"
                               TextColor="#999"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>

        </Grid>

        <!-- Bottom Navigation Bar -->
        <Grid Grid.Row="2"
              BackgroundColor="#8B0000"
              ColumnDefinitions="*,*,*,*,*"
              Padding="0,10,0,18"
              HeightRequest="72">

            <VerticalStackLayout Grid.Column="0"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Label Text="⊞"
                       FontSize="22"
                       HorizontalOptions="Center"
                       TextColor="White"/>
                <Label Text="Dashboard"
                       FontSize="9"
                       TextColor="White"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Label Text="📄"
                       FontSize="20"
                       HorizontalOptions="Center"
                       TextColor="White"/>
                <Label Text="Reports"
                       FontSize="9"
                       TextColor="White"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Active -->
            <VerticalStackLayout Grid.Column="2"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Label Text="📦"
                       FontSize="20"
                       HorizontalOptions="Center"
                       TextColor="#FFE5E5"/>
                <Label Text="Items"
                       FontSize="9"
                       TextColor="#FFE5E5"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <BoxView HeightRequest="2"
                         WidthRequest="24"
                         BackgroundColor="#FFE5E5"
                         HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Label Text="✓"
                       FontSize="20"
                       HorizontalOptions="Center"
                       TextColor="White"/>
                <Label Text="Verify"
                       FontSize="9"
                       TextColor="White"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="4"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Label Text="✔"
                       FontSize="20"
                       HorizontalOptions="Center"
                       TextColor="White"/>
                <Label Text="Returned"
                       FontSize="9"
                       TextColor="White"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
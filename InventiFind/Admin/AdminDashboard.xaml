<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventiFind.AdminDashboard"
             BackgroundColor="#F2F4F7"
             Shell.NavBarIsVisible="False">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" IsEnabled="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="#C8102E"
              Padding="20,40,20,24"
              HeightRequest="140">

            <VerticalStackLayout Spacing="2">
                <Label Text="Dashboard"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="White"/>

                <Label Text="Overview of lost and found reports"
                       FontSize="13"
                       TextColor="#FDECEC"/>
            </VerticalStackLayout>
        </Grid>

        <!-- CONTENT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,16,16,20"
                                 Spacing="14">

                <!-- FIXED STATS -->
                <Grid ColumnDefinitions="*,*"
      RowDefinitions="Auto,Auto"
      ColumnSpacing="10"
      RowSpacing="10">

                    <!-- Total Reports -->
                    <Frame Grid.Row="0" Grid.Column="0"
           BackgroundColor="White"
           CornerRadius="18"
           Padding="14"
           HeightRequest="120"
           HasShadow="False"
           BorderColor="#E5E7EB">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                                <Frame BackgroundColor="#FDECEC"
                       WidthRequest="36"
                       HeightRequest="36"
                       CornerRadius="12"
                       Padding="7"
                       HasShadow="False">
                                    <Image Source="report.png" Aspect="AspectFit"/>
                                </Frame>

                                <Label Grid.Column="1"
                       x:Name="TotalReportsTodayLabel"
                       Text="+0 today"
                       FontSize="11"
                       TextColor="#C8102E"
                       HorizontalOptions="End"
                       VerticalOptions="Center"/>
                            </Grid>

                            <Label Grid.Row="1"
                   x:Name="TotalReportsLabel"
                   Text="0"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#111827"
                   VerticalOptions="Center"/>

                            <Label Grid.Row="2"
                   Text="Total Reports"
                   FontSize="12"
                   TextColor="#6B7280"/>
                        </Grid>
                    </Frame>

                    <!-- Lost Reports -->
                    <Frame Grid.Row="0" Grid.Column="1"
           BackgroundColor="White"
           CornerRadius="18"
           Padding="14"
           HeightRequest="120"
           HasShadow="False"
           BorderColor="#E5E7EB">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                                <Frame BackgroundColor="#FDECEC"
                       WidthRequest="36"
                       HeightRequest="36"
                       CornerRadius="12"
                       Padding="7"
                       HasShadow="False">
                                    <Image Source="notif.png" Aspect="AspectFit"/>
                                </Frame>

                                <Label Grid.Column="1"
                       x:Name="LostTodayLabel"
                       Text="+0 today"
                       FontSize="11"
                       TextColor="#C8102E"
                       HorizontalOptions="End"
                       VerticalOptions="Center"/>
                            </Grid>

                            <Label Grid.Row="1"
                   x:Name="LostItemsLabel"
                   Text="0"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#111827"
                   VerticalOptions="Center"/>

                            <Label Grid.Row="2"
                   Text="Lost Reports"
                   FontSize="12"
                   TextColor="#6B7280"/>
                        </Grid>
                    </Frame>

                    <!-- Found Reports -->
                    <Frame Grid.Row="1" Grid.Column="0"
           BackgroundColor="White"
           CornerRadius="18"
           Padding="14"
           HeightRequest="120"
           HasShadow="False"
           BorderColor="#E5E7EB">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                                <Frame BackgroundColor="#FDECEC"
                       WidthRequest="36"
                       HeightRequest="36"
                       CornerRadius="12"
                       Padding="7"
                       HasShadow="False">
                                    <Image Source="box.png" Aspect="AspectFit"/>
                                </Frame>

                                <Label Grid.Column="1"
                       x:Name="FoundTodayLabel"
                       Text="+0 today"
                       FontSize="11"
                       TextColor="#C8102E"
                       HorizontalOptions="End"
                       VerticalOptions="Center"/>
                            </Grid>

                            <Label Grid.Row="1"
                   x:Name="FoundItemsLabel"
                   Text="0"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#111827"
                   VerticalOptions="Center"/>

                            <Label Grid.Row="2"
                   Text="Found Reports"
                   FontSize="12"
                   TextColor="#6B7280"/>
                        </Grid>
                    </Frame>

                    <!-- Total Users -->
                    <Frame Grid.Row="1" Grid.Column="1"
           BackgroundColor="White"
           CornerRadius="18"
           Padding="14"
           HeightRequest="120"
           HasShadow="False"
           BorderColor="#E5E7EB">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                                <Frame BackgroundColor="#FDECEC"
                       WidthRequest="36"
                       HeightRequest="36"
                       CornerRadius="12"
                       Padding="7"
                       HasShadow="False">
                                    <Image Source="home.png" Aspect="AspectFit"/>
                                </Frame>

                                <Label Grid.Column="1"
                       x:Name="UsersTodayLabel"
                       Text="+0 today"
                       FontSize="11"
                       TextColor="#C8102E"
                       HorizontalOptions="End"
                       VerticalOptions="Center"/>
                            </Grid>

                            <Label Grid.Row="1"
                   x:Name="TotalUsersLabel"
                   Text="0"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#111827"
                   VerticalOptions="Center"/>

                            <Label Grid.Row="2"
                   Text="Total Users"
                   FontSize="12"
                   TextColor="#6B7280"/>
                        </Grid>
                    </Frame>

                </Grid>

                <!-- CATEGORIES -->
                <Frame BackgroundColor="White"
                       CornerRadius="18"
                       Padding="16"
                       HasShadow="False"
                       BorderColor="#E5E7EB">

                    <VerticalStackLayout Spacing="14">
                        <Label Text="Categories"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#111827"/>

                        <Grid ColumnDefinitions="*,*,*,*"
                              ColumnSpacing="10">

                            <VerticalStackLayout Grid.Column="0" Spacing="6" HorizontalOptions="Center">
                                <Frame BackgroundColor="White"
                                       CornerRadius="16"
                                       Padding="12"
                                       BorderColor="#E5E7EB"
                                       HasShadow="False"
                                       WidthRequest="62"
                                       HeightRequest="62">
                                    <Image Source="mobile.png" Aspect="AspectFit"/>
                                </Frame>
                                <Label Text="Phone" FontSize="11" TextColor="#6B7280"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="6" HorizontalOptions="Center">
                                <Frame BackgroundColor="White"
                                       CornerRadius="16"
                                       Padding="12"
                                       BorderColor="#E5E7EB"
                                       HasShadow="False"
                                       WidthRequest="62"
                                       HeightRequest="62">
                                    <Image Source="wallet.png" Aspect="AspectFit"/>
                                </Frame>
                                <Label Text="Wallet" FontSize="11" TextColor="#6B7280"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2" Spacing="6" HorizontalOptions="Center">
                                <Frame BackgroundColor="White"
                                       CornerRadius="16"
                                       Padding="12"
                                       BorderColor="#E5E7EB"
                                       HasShadow="False"
                                       WidthRequest="62"
                                       HeightRequest="62">
                                    <Image Source="id.png" Aspect="AspectFit"/>
                                </Frame>
                                <Label Text="ID" FontSize="11" TextColor="#6B7280"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="3" Spacing="6" HorizontalOptions="Center">
                                <Frame BackgroundColor="White"
                                       CornerRadius="16"
                                       Padding="12"
                                       BorderColor="#E5E7EB"
                                       HasShadow="False"
                                       WidthRequest="62"
                                       HeightRequest="62">
                                    <Image Source="watch1.png" Aspect="AspectFit"/>
                                </Frame>
                                <Label Text="Watch" FontSize="11" TextColor="#6B7280"/>
                            </VerticalStackLayout>

                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- RECENT REPORTS WITH INNER SCROLL -->
                <Frame BackgroundColor="White"
                       CornerRadius="18"
                       Padding="16"
                       HasShadow="False"
                       BorderColor="#E5E7EB">

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Recent Reports"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#111827"/>

                        <Grid HeightRequest="270">
                            <CollectionView x:Name="RecentReportsCollection"
                                            SelectionMode="None">

                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical"
                                                       ItemSpacing="8"/>
                                </CollectionView.ItemsLayout>

                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Frame BackgroundColor="#F9FAFB"
                                               CornerRadius="14"
                                               Padding="12"
                                               HasShadow="False"
                                               BorderColor="#E5E7EB">

                                            <Grid ColumnDefinitions="*,Auto"
                                                  RowDefinitions="Auto,Auto,Auto"
                                                  RowSpacing="4">

                                                <Label Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       TextColor="#111827"
                                                       LineBreakMode="TailTruncation"/>

                                                <Frame Grid.Row="0"
                                                       Grid.Column="1"
                                                       BackgroundColor="{Binding BadgeColor}"
                                                       CornerRadius="10"
                                                       Padding="8,3"
                                                       HasShadow="False">
                                                    <Label Text="{Binding RType}"
                                                           FontSize="10"
                                                           FontAttributes="Bold"
                                                           TextColor="White"/>
                                                </Frame>

                                                <Label Grid.Row="1"
                                                       Grid.ColumnSpan="2"
                                                       Text="{Binding Description}"
                                                       FontSize="12"
                                                       TextColor="#6B7280"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="2"/>

                                                <Label Grid.Row="2"
                                                       Grid.ColumnSpan="2"
                                                       Text="{Binding TimeAgo}"
                                                       FontSize="11"
                                                       TextColor="#9CA3AF"/>
                                            </Grid>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>

                            </CollectionView>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- NAVIGATION -->
        <Grid Grid.Row="2"
              BackgroundColor="White"
              ColumnDefinitions="*,*,*,*"
              HeightRequest="70"
              Padding="0,10">

            <!-- Dashboard Active -->
            <VerticalStackLayout Grid.Column="0"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="home.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Dashboard"
                       FontSize="11"
                       TextColor="#C8102E"
                       FontAttributes="Bold"/>
                <BoxView HeightRequest="2"
                         WidthRequest="28"
                         BackgroundColor="#C8102E"/>
            </VerticalStackLayout>

            <!-- Reports -->
            <VerticalStackLayout Grid.Column="1"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="report.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Reports"
                       FontSize="11"
                       TextColor="#9CA3AF"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Verify -->
            <VerticalStackLayout Grid.Column="2"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="notif.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Verify"
                       FontSize="11"
                       TextColor="#9CA3AF"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnVerifyTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Returned -->
            <VerticalStackLayout Grid.Column="3"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="box.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Returned"
                       FontSize="11"
                       TextColor="#9CA3AF"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReturnedTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>
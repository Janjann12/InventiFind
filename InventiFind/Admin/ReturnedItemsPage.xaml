<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:InventiFind"
             x:Class="InventiFind.ReturnedItemsPage"
             Title="Returned Items"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F2F4F7">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="#C8102E"
              Padding="20,40,20,24"
              HeightRequest="240">

            <VerticalStackLayout Spacing="18">

                <!-- Title -->
                <HorizontalStackLayout Spacing="12">

                    <Frame WidthRequest="48"
                           HeightRequest="48"
                           CornerRadius="24"
                           BackgroundColor="#33FFFFFF"
                           Padding="0"
                           HasShadow="False">
                        <Image Source="box.png"
                               WidthRequest="26"
                               HeightRequest="26"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Frame>

                    <VerticalStackLayout Spacing="2"
                                         VerticalOptions="Center">

                        <Label Text="Returned Items"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="White"/>

                        <Label x:Name="SubtitleLabel"
                               Text="Resolved items"
                               FontSize="13"
                               TextColor="#FDECEC"/>
                    </VerticalStackLayout>

                </HorizontalStackLayout>

                <!-- STATS -->
                <!-- STATS -->
                <Grid ColumnDefinitions="*,*"
      ColumnSpacing="12">

                    <Frame Grid.Column="0"
           BackgroundColor="#33FFFFFF"
           CornerRadius="16"
           Padding="14,12"
           HasShadow="False"
           BorderColor="#22FFFFFF">
                        <VerticalStackLayout Spacing="2">
                            <Label x:Name="TotalReturnedLabel"
                   Text="0"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="White"/>
                            <Label Text="Total Returned"
                   FontSize="11"
                   TextColor="#FDECEC"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1"
           BackgroundColor="#33FFFFFF"
           CornerRadius="16"
           Padding="14,12"
           HasShadow="False"
           BorderColor="#22FFFFFF">
                        <VerticalStackLayout Spacing="2">
                            <Label x:Name="ThisMonthLabel"
                   Text="—"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="White"/>
                            <Label Text="This Month"
                   FontSize="11"
                   TextColor="#FDECEC"/>
                        </VerticalStackLayout>
                    </Frame>

                </Grid>

                <Button Text="Generate Report"
                        Clicked="OnGenerateReportClicked"
                        BackgroundColor="White"
                        TextColor="#C8102E"
                        FontAttributes="Bold"
                        CornerRadius="14"
                        HeightRequest="44"
                        HorizontalOptions="End"/>

            </VerticalStackLayout>
        </Grid>

        <!-- CONTENT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,18,18,24"
                                 Spacing="12">

                <Label Text="RETURN TIMELINE"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="#6B7280"
                       CharacterSpacing="1.4"/>

                <!-- Loading -->
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False"
                                   IsVisible="False"
                                   Color="#C8102E"
                                   HorizontalOptions="Center"
                                   Margin="0,28"/>

                <!-- Empty -->
                <VerticalStackLayout x:Name="EmptyState"
                                     IsVisible="False"
                                     HorizontalOptions="Center"
                                     Margin="0,60"
                                     Spacing="10">

                    <Image Source="box.png"
                           WidthRequest="60"
                           HeightRequest="60"/>

                    <Label Text="No returned items yet"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           HorizontalOptions="Center"/>

                    <Label Text="Returned items will appear here once resolved"
                           FontSize="13"
                           TextColor="#6B7280"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- COLLECTION -->
                <CollectionView x:Name="ReturnedCollection"
                                IsVisible="False"
                                SelectionMode="None">

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="local:ReturnedItem">

                            <Grid ColumnDefinitions="40,*"
              Padding="0,0,0,6">

                                <!-- TIMELINE -->
                                <Grid Grid.Column="0"
                  RowDefinitions="*,Auto,*"
                  HorizontalOptions="Center"
                  VerticalOptions="FillAndExpand">

                                    <!-- TOP LINE -->
                                    <BoxView Grid.Row="0"
                         WidthRequest="2"
                         Color="#E5E7EB"
                         HorizontalOptions="Center"
                         VerticalOptions="Fill"/>

                                    <!-- DOT -->
                                    <Frame Grid.Row="1"
                       WidthRequest="14"
                       HeightRequest="14"
                       CornerRadius="7"
                       Padding="0"
                       HasShadow="False"
                       BackgroundColor="{Binding DotColor}"
                       BorderColor="#C8102E"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>

                                    <!-- BOTTOM LINE -->
                                    <BoxView Grid.Row="2"
                         WidthRequest="2"
                         Color="#E5E7EB"
                         HorizontalOptions="Center"
                         VerticalOptions="Fill"/>
                                </Grid>

                                <!-- CARD -->
                                <Frame Grid.Column="1"
                   BackgroundColor="White"
                   CornerRadius="18"
                   Padding="14"
                   HasShadow="False"
                   BorderColor="#E5E7EB">

                                    <VerticalStackLayout Spacing="6">

                                        <Grid ColumnDefinitions="*,Auto">

                                            <Label Text="{Binding ItemName}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#111827"/>
                                            <Frame BackgroundColor="{Binding BadgeBg}"
                               CornerRadius="10"
                               Padding="8,3"
                               HasShadow="False"
                               Grid.Column="1">
                                                <Label Text="{Binding ConditionLabel}"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="{Binding BadgeFg}"/>
                                            </Frame>

                                        </Grid>

                                        <Label Text="{Binding OwnerLine}"
                           FontSize="12"
                           TextColor="#6B7280"/>

                                        <Label Text="{Binding Notes}"
                           FontSize="12"
                           TextColor="#4B5563"
                           LineBreakMode="TailTruncation"
                           MaxLines="2"/>

                                        <HorizontalStackLayout Spacing="12">

                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="📅" FontSize="11"/>
                                                <Label Text="{Binding ResolvedDate}"
                                   FontSize="11"
                                   TextColor="#9CA3AF"/>
                                            </HorizontalStackLayout>

                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="👤" FontSize="11"/>
                                                <Label Text="{Binding VerifiedByName}"
                                   FontSize="11"
                                   TextColor="#9CA3AF"/>
                                            </HorizontalStackLayout>

                                        </HorizontalStackLayout>

                                    </VerticalStackLayout>

                                </Frame>

                            </Grid>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="2"
      BackgroundColor="White"
      HeightRequest="70"
      ColumnDefinitions="*,*,*,*,*"
      Padding="0,10">

            <!-- Dashboard -->
            <VerticalStackLayout Grid.Column="0"
                         Spacing="2"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <Image Source="home.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Dashboard"
               FontSize="11"
               TextColor="#9CA3AF"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDashboardTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Reports -->
            <VerticalStackLayout Grid.Column="1"
                         Spacing="2"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <Image Source="report.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Reports"
               FontSize="11"
               TextColor="#9CA3AF"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReportsTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Verify -->
            <Grid Grid.Column="2"
          HorizontalOptions="Center">

                <VerticalStackLayout Spacing="2"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">
                    <Image Source="notif.png" WidthRequest="28" HeightRequest="28"/>
                    <Label Text="Verify"
                   FontSize="11"
                   TextColor="#9CA3AF"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVerifyTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <Frame x:Name="VerifyBadge"
               WidthRequest="16"
               HeightRequest="16"
               CornerRadius="8"
               BackgroundColor="#C8102E"
               Padding="0"
               HasShadow="False"
               HorizontalOptions="End"
               VerticalOptions="Start"
               Margin="0,0,4,0"
               IsVisible="False">

                    <Label x:Name="VerifyBadgeLabel"
                   Text="0"
                   FontSize="9"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
                </Frame>
            </Grid>

            <!-- Returned ACTIVE -->
            <VerticalStackLayout Grid.Column="3"
                         Spacing="2"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                <Image Source="box.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Returned"
               FontSize="11"
               TextColor="#C8102E"
               FontAttributes="Bold"/>
                <BoxView HeightRequest="2"
                 WidthRequest="28"
                 BackgroundColor="#C8102E"
                 CornerRadius="1"
                 Margin="0,-2,0,0"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="4"
                                 Spacing="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Image Source="logout.png" WidthRequest="28" HeightRequest="28"/>
                <Label Text="Logout" FontSize="11" TextColor="#9CA3AF"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>